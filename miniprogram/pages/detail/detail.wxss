/* pages/detail/detail.wxss - 详情页样式 */
.container {
  padding-bottom: 120rpx;
}

/* 轮播图 */
.swiper {
  width: 100%;
  height: 480rpx;
}

.swiper-img {
  width: 100%;
  height: 100%;
}

/* 基本信息 */
.info-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.meta {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.rating {
  font-size: 28rpx;
  color: #FF7D00;
  margin-right: 20rpx;
}

.review-count {
  font-size: 24rpx;
  color: #86909C;
  margin-right: 20rpx;
}

.type {
  font-size: 24rpx;
  color: #165DFF;
  background: #E8F3FF;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.price {
  margin-bottom: 20rpx;
}

.price-label {
  font-size: 28rpx;
  color: #666;
}

.price-value {
  font-size: 36rpx;
  color: #F53F3F;
  font-weight: bold;
}

.address {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.address-icon {
  margin-right: 10rpx;
}

/* 区块 */
.section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 8rpx solid #165DFF;
}

/* 设施 */
.facility-list {
  display: flex;
  flex-wrap: wrap;
}

.facility-item {
  background: #F5F7FA;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #666;
}

/* 入住须知 */
.rules {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 日期选择 */
.date-picker {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.date-item {
  flex: 1;
  background: #F5F7FA;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.date-item:last-child {
  margin-right: 0;
}

.date-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.date-value {
  font-size: 28rpx;
  color: #333;
}

/* 房型卡片 */
.room-card {
  background: #F5F7FA;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.room-img {
  width: 100%;
  height: 320rpx;
}

.room-info {
  padding: 20rpx;
}

.room-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.room-desc {
  font-size: 24rpx;
  color: #86909C;
  margin-bottom: 16rpx;
}

.room-meta {
  display: flex;
  margin-bottom: 16rpx;
}

.room-meta text {
  font-size: 24rpx;
  color: #666;
  margin-right: 20rpx;
}

.room-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.room-price {
  font-size: 32rpx;
  color: #F53F3F;
  font-weight: bold;
}

.room-stock {
  font-size: 24rpx;
  color: #86909C;
}

.book-btn {
  background: #165DFF;
  color: #fff;
  font-size: 28rpx;
  padding: 12rpx 30rpx;
  border-radius: 8rpx;
  border: none;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
