<view class="page">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索游记/话题/用户..." value="{{keyword}}" bindinput="onSearchInput" confirm-type="search" bindconfirm="onSearch" />
    <button class="search-btn" bindtap="onSearch" disabled="{{searching}}">搜索</button>
  </view>

  <view wx:if="{{searching}}" class="status">搜索中...</view>

  <view wx:if="{{noResult}}" class="status" style="padding: 80rpx;">未找到相关内容</view>

  <!-- 话题结果 -->
  <view wx:if="{{topics.length > 0}}" class="section">
    <view class="section-title">话题</view>
    <view wx:for="{{topics}}" wx:key="id" class="topic-item" bindtap="goTopic" data-id="{{item.id}}">
      <text class="topic-name">#{{item.name}}</text>
      <text class="topic-count">{{item.note_count}} 篇游记</text>
    </view>
  </view>

  <!-- 游记结果 -->
  <view wx:if="{{notes.length > 0}}" class="section">
    <view class="section-title">游记</view>
    <view wx:for="{{notes}}" wx:key="id" class="note-item" bindtap="goDetail" data-id="{{item.id}}">
      <image wx:if="{{item.images && item.images[0]}}" src="{{item.images[0]}}" class="note-cover" mode="aspectFill" />
      <view wx:else class="note-no-cover"></view>
      <view class="note-info">
        <view class="note-title">{{item.title}}</view>
        <view class="note-meta">{{item.author_nickname || '匿名'}} · ❤ {{item.like_count || 0}}</view>
      </view>
    </view>
  </view>
</view>
