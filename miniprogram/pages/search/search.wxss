.page { padding: 20rpx; }
.search-bar { display: flex; gap: 16rpx; margin-bottom: 30rpx; }
.search-input { flex: 1; padding: 20rpx 24rpx; border: 1rpx solid #e0e0e0; border-radius: 40rpx; font-size: 28rpx; background: #fff; }
.search-btn { padding: 20rpx 32rpx; background: #1677ff; color: #fff; border-radius: 40rpx; font-size: 28rpx; border: none; }
.status { text-align: center; padding: 40rpx; color: #999; font-size: 28rpx; }
.section { margin-bottom: 30rpx; }
.section-title { font-size: 32rpx; font-weight: bold; margin-bottom: 16rpx; }
.topic-item { display: flex; justify-content: space-between; padding: 20rpx 16rpx; background: #fff; border-radius: 12rpx; margin-bottom: 12rpx; }
.topic-name { color: #1677ff; font-size: 30rpx; }
.topic-count { font-size: 26rpx; color: #999; }
.note-item { display: flex; gap: 16rpx; padding: 16rpx; background: #fff; border-radius: 12rpx; margin-bottom: 16rpx; }
.note-cover { width: 120rpx; height: 120rpx; border-radius: 10rpx; }
.note-no-cover { width: 120rpx; height: 120rpx; border-radius: 10rpx; background: linear-gradient(135deg, #667eea, #764ba2); }
.note-info { flex: 1; display: flex; flex-direction: column; justify-content: center; }
.note-title { font-size: 30rpx; font-weight: 500; margin-bottom: 8rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.note-meta { font-size: 26rpx; color: #999; }
