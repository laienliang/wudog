.fav-item {
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.fav-main {
  display: flex;
  margin-bottom: 16rpx;
}

.fav-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.fav-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.fav-name {
  font-size: 28rpx;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.fav-price {
  font-size: 32rpx;
  color: #f5222d;
  font-weight: 600;
}

.fav-actions {
  display: flex;
  justify-content: flex-end;
}

.unfav-btn {
  font-size: 24rpx;
  color: #ff4d4f;
  padding: 8rpx 16rpx;
}
