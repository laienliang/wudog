.address-item {
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.addr-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.addr-name {
  font-size: 30rpx;
  font-weight: 600;
}

.addr-phone {
  font-size: 28rpx;
  color: #666;
}

.addr-default {
  font-size: 22rpx;
  color: #c9a96e;
  background: rgba(201,169,110,0.1);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.addr-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.addr-actions {
  display: flex;
  gap: 24rpx;
}

.addr-action {
  font-size: 24rpx;
  color: #c9a96e;
}

.addr-action.delete {
  color: #ff4d4f;
}

.add-form {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-item input {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.form-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.picker {
  flex: 1;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.picker.disabled {
  color: #999;
}

.save-btn {
  background: #c9a96e;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-top: 10rpx;
}

.add-btn {
  text-align: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  color: #c9a96e;
  font-size: 30rpx;
}
