<view class="container">
  <!-- 地址列表 -->
  <view class="address-list">
    <view class="address-item card" wx:for="{{addresses}}" wx:key="id" bindtap="onSelectAddress" data-index="{{index}}">
      <view class="addr-header">
        <text class="addr-name">{{item.name}}</text>
        <text class="addr-phone">{{item.phone}}</text>
        <text class="addr-default" wx:if="{{item.is_default}}">默认</text>
      </view>
      <view class="addr-detail">{{item.province}} {{item.city}} {{item.district}} {{item.town || ''}} {{item.detail}}</view>
      <view class="addr-actions">
        <text class="addr-action" wx:if="{{!item.is_default}}" catchtap="onSetDefault" data-id="{{item.id}}">设为默认</text>
        <text class="addr-action delete" catchtap="onDelete" data-id="{{item.id}}">删除</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{addresses.length === 0 && !showAdd}}">暂无收货地址</view>

  <!-- 新增地址表单 -->
  <view class="add-form card" wx:if="{{showAdd}}">
    <view class="form-item">
      <input placeholder="收货人" value="{{name}}" bindinput="onNameInput" />
    </view>
    <view class="form-item">
      <input placeholder="手机号（11位）" type="number" maxlength="11" value="{{phone}}" bindinput="onPhoneInput" />
    </view>
    <view class="form-row">
      <picker bindchange="onProvinceChange" value="{{provinceIndex}}" range="{{provinces}}">
        <view class="picker">{{province || '省份'}}</view>
      </picker>
      <picker bindchange="onCityChange" value="{{cityIndex}}" range="{{cities}}" disabled="{{!province}}">
        <view class="picker {{!province ? 'disabled' : ''}}">{{city || '城市'}}</view>
      </picker>
    </view>
    <view class="form-row">
      <picker bindchange="onDistrictChange" value="{{districtIndex}}" range="{{districts}}" disabled="{{!city}}">
        <view class="picker {{!city ? 'disabled' : ''}}">{{district || '区/县'}}</view>
      </picker>
    </view>
    <view class="form-item">
      <input placeholder="详细地址（路名、门牌号等）" value="{{detail}}" bindinput="onDetailInput" />
    </view>
    <button class="save-btn" bindtap="onAdd">保存</button>
  </view>

  <!-- 新增按钮 -->
  <view class="add-btn" bindtap="toggleAdd">{{showAdd ? '取消' : '+ 新增地址'}}</view>
</view>
