.page { padding-bottom: 20rpx; }
.category-bar { white-space: nowrap; padding: 16rpx 20rpx; background: #fff; }
.cat-item { display: inline-block; padding: 10rpx 28rpx; margin-right: 16rpx; border-radius: 28rpx; font-size: 26rpx; color: #666; background: #f5f5f5; }
.cat-item.active { background: #1677ff; color: #fff; }
.sort-bar { display: flex; padding: 16rpx 20rpx; background: #fff; border-top: 1rpx solid #f0f0f0; gap: 24rpx; }
.sort-item { font-size: 24rpx; color: #999; }
.sort-item.active { color: #1677ff; font-weight: bold; }
.product-grid { display: flex; flex-wrap: wrap; padding: 20rpx; gap: 16rpx; }
.product-card { width: calc(50% - 8rpx); background: #fff; border-radius: 12rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.product-img { width: 100%; height: 340rpx; background: #f5f5f5; }
.product-info { padding: 16rpx; }
.product-title { font-size: 28rpx; font-weight: bold; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 8rpx; }
.product-price-row { display: flex; align-items: baseline; gap: 10rpx; }
.product-price { font-size: 32rpx; font-weight: bold; color: #ff4d4f; }
.product-market-price { font-size: 22rpx; color: #ccc; text-decoration: line-through; }
.product-sales { font-size: 22rpx; color: #ccc; margin-top: 6rpx; }
.empty { text-align: center; padding: 100rpx 0; color: #ccc; }
.no-more { text-align: center; padding: 30rpx 0; color: #ccc; font-size: 24rpx; }
