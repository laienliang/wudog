.page { padding-bottom: 120rpx; }
.loading { text-align: center; padding: 100rpx; color: #999; }
.swiper { width: 100%; height: 600rpx; background: #f5f5f5; }
.swiper-img { width: 100%; height: 100%; }
.no-img { width: 100%; height: 400rpx; background: #f5f5f5; display: flex; align-items: center; justify-content: center; color: #ccc; font-size: 60rpx; }
.info-card { padding: 28rpx; background: #fff; margin-bottom: 16rpx; }
.title { font-size: 34rpx; font-weight: bold; margin-bottom: 6rpx; }
.subtitle { font-size: 24rpx; color: #999; margin-bottom: 16rpx; }
.price-row { display: flex; align-items: baseline; gap: 16rpx; margin-bottom: 8rpx; }
.price { font-size: 40rpx; font-weight: bold; color: #ff4d4f; }
.market-price { font-size: 26rpx; color: #ccc; text-decoration: line-through; }
.stock-sales { font-size: 22rpx; color: #999; }
.sku-section { padding: 24rpx 28rpx; background: #fff; margin-bottom: 16rpx; }
.section-title { font-size: 26rpx; color: #666; margin-bottom: 16rpx; }
.sku-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.sku-item { padding: 12rpx 28rpx; border: 1rpx solid #e0e0e0; border-radius: 8rpx; font-size: 26rpx; }
.sku-item.active { border-color: #1677ff; color: #1677ff; background: #f0f5ff; }
.qty-section { padding: 24rpx 28rpx; background: #fff; margin-bottom: 16rpx; display: flex; justify-content: space-between; align-items: center; }
.qty-stepper { display: flex; align-items: center; }
.qty-btn { width: 56rpx; height: 56rpx; border: 1rpx solid #e0e0e0; display: flex; align-items: center; justify-content: center; font-size: 32rpx; }
.qty-value { width: 80rpx; height: 56rpx; border-top: 1rpx solid #e0e0e0; border-bottom: 1rpx solid #e0e0e0; display: flex; align-items: center; justify-content: center; font-size: 28rpx; }
.craft-card { padding: 24rpx 28rpx; background: #fff; margin-bottom: 16rpx; font-size: 26rpx; color: #555; line-height: 1.6; }
.detail-card { padding: 24rpx 28rpx; background: #fff; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 16rpx 28rpx; display: flex; gap: 20rpx; box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.05); }
.btn-cart { flex: 1; height: 80rpx; line-height: 80rpx; text-align: center; background: #fff; color: #1677ff; border: 1rpx solid #1677ff; border-radius: 12rpx; font-size: 30rpx; }
.btn-buy { flex: 1; height: 80rpx; line-height: 80rpx; text-align: center; background: #1677ff; color: #fff; border: none; border-radius: 12rpx; font-size: 30rpx; }
