<view class="page">
  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <view wx:elif="{{!product}}" class="loading">商品不存在</view>

  <block wx:else>
    <!-- Image swiper -->
    <swiper class="swiper" wx:if="{{allImages.length > 0}}" current="{{currentImage}}" bindchange="onSwiperChange" indicator-dots="{{allImages.length > 1}}" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#fff">
      <swiper-item wx:for="{{allImages}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFit" class="swiper-img" />
      </swiper-item>
    </swiper>
    <view wx:else class="no-img">暂无图片</view>

    <!-- Info -->
    <view class="info-card">
      <view class="title">{{product.title}}</view>
      <view class="subtitle" wx:if="{{product.subtitle}}">{{product.subtitle}}</view>
      <view class="price-row">
        <text class="price">¥{{selectedSku ? (selectedSku.price || product.price) : product.price}}</text>
        <text class="market-price" wx:if="{{product.marketPrice}}">¥{{product.marketPrice}}</text>
      </view>
      <view class="stock-sales">库存: {{selectedSku ? selectedSku.stock : product.stock}} | 销量: {{product.sales}}</view>
    </view>

    <!-- SKU selector -->
    <view class="sku-section" wx:if="{{product.skus && product.skus.length > 0}}">
      <view class="section-title">规格</view>
      <view class="sku-list">
        <view class="sku-item {{selectedSku && selectedSku.id === item.id ? 'active' : ''}}" wx:for="{{product.skus}}" wx:key="id" data-id="{{item.id}}" bindtap="onSkuTap">
          {{item.specName}} {{item.price ? '¥' + item.price : ''}}
        </view>
      </view>
    </view>

    <!-- Quantity -->
    <view class="qty-section">
      <view class="section-title">数量</view>
      <view class="qty-stepper">
        <view class="qty-btn" bindtap="onQtyMinus">-</view>
        <view class="qty-value">{{quantity}}</view>
        <view class="qty-btn" bindtap="onQtyPlus">+</view>
      </view>
    </view>

    <!-- Craft info -->
    <view class="craft-card" wx:if="{{product.craftIntro}}">
      <view class="section-title">工艺介绍</view>
      <text>{{product.craftIntro}}</text>
    </view>
    <view class="craft-card" wx:if="{{product.inheritorName}}">
      <view class="section-title">传承人</view>
      <text>{{product.inheritorName}}</text>
    </view>

    <!-- Rich detail -->
    <view class="detail-card" wx:if="{{product.detail}}">
      <view class="section-title">商品详情</view>
      <rich-text nodes="{{product.detail}}" />
    </view>

    <!-- Bottom bar -->
    <view class="bottom-bar">
      <button class="btn-cart" bindtap="addToCart">加入购物车</button>
      <button class="btn-buy" bindtap="buyNow">立即购买</button>
    </view>
  </block>
</view>
