<!--pages/route/detail.wxml-->
<view class="container">
  <view class="back-nav" bindtap="goBack">← 返回</view>

  <view class="detail-section" wx:if="{{route}}">
    <image class="cover" src="{{route.coverImage}}" mode="aspectFill" />
    <view class="title">{{route.name}}</view>
    <view class="info">📅 {{route.durationDays}}天 · ¥{{route.price}}/人</view>
    <view class="info">👥 {{route.minPeople}}-{{route.maxPeople}}人成团</view>
    <view class="desc">{{route.description || ''}}</view>
  </view>

  <!-- 行程 -->
  <view class="detail-section" wx:if="{{route && route.itineraries.length > 0}}">
    <view class="section-title">行程详情</view>
    <block wx:for="{{route.itineraries}}" wx:key="id">
      <view style="padding-left: 20rpx; border-left: 4rpx solid #1677ff; margin-bottom: 24rpx;">
        <view style="font-weight: bold; font-size: 28rpx; margin-bottom: 8rpx;">
          第{{item.dayOrder}}天 · {{item.title}}
        </view>
        <view style="font-size: 24rpx; color: #666; line-height: 1.6;">{{item.content}}</view>
      </view>
    </block>
  </view>

  <!-- 底部购买栏 -->
  <view class="bottom-bar" wx:if="{{route}}">
    <view class="total">
      <text style="font-size: 22rpx; color: #999;">¥{{route.price}}/人</text>
    </view>
    <button class="btn btn-primary" bindtap="goBuy">立即预订</button>
  </view>
</view>
