<!--pages/route/list.wxml-->
<view class="container">
  <view class="page-title">路线套餐</view>
  <view class="card-grid">
    <block wx:for="{{routes}}" wx:key="id">
      <view class="card-col" bindtap="goDetail" data-id="{{item.id}}">
        <view class="card">
          <view class="card-img-placeholder"></view>
          <view class="card-body">
            <view class="card-title">{{item.name}}</view>
            <view class="card-desc">{{item.durationDays}}天 · {{item.minPeople}}-{{item.maxPeople}}人</view>
            <view class="card-price">¥{{item.price}}</view>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
