.page-container { padding: 24rpx; min-height: 100vh; background: #F5F7FA; }
.loading-text { text-align: center; padding: 120rpx 0; color: #9CA3AF; font-size: 28rpx; }
.swiper { height: 500rpx; border-radius: 20rpx; overflow: hidden; margin-bottom: 24rpx; }
.swiper-img { width: 100%; height: 100%; }
.no-img { height: 300rpx; display: flex; align-items: center; justify-content: center; background: #E5E7EB; border-radius: 20rpx; color: #9CA3AF; font-size: 28rpx; }
.info-card { background: #fff; border-radius: 20rpx; padding: 32rpx; margin-bottom: 24rpx; }
.name { font-size: 36rpx; font-weight: 700; color: #1A1A2E; margin-bottom: 12rpx; }
.address { font-size: 26rpx; color: #9CA3AF; margin-bottom: 16rpx; }
.tags { margin-bottom: 16rpx; display: flex; flex-wrap: wrap; gap: 12rpx; }
.tag { display: inline-block; padding: 6rpx 20rpx; border-radius: 8rpx; font-size: 22rpx; background: #E8F0FA; color: #1F5FA8; }
.rating-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.stars { color: #F59E0B; font-size: 28rpx; }
.rating-num { font-size: 26rpx; color: #6B7280; }
.desc { font-size: 28rpx; color: #4B5563; line-height: 1.8; }
.section-title { font-size: 34rpx; font-weight: 700; color: #1A1A2E; margin: 32rpx 0 20rpx; }
.empty-hint { text-align: center; padding: 40rpx 0; color: #9CA3AF; font-size: 28rpx; }
.room-card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 16rpx; display: flex; align-items: center; justify-content: space-between; }
.room-name { font-size: 30rpx; font-weight: 600; color: #1A1A2E; margin-bottom: 8rpx; }
.room-meta { font-size: 24rpx; color: #9CA3AF; margin-bottom: 6rpx; }
.room-price { font-size: 28rpx; color: #E85D2F; font-weight: 700; }
.unit { font-size: 22rpx; font-weight: 400; color: #9CA3AF; margin-left: 4rpx; }
.book-btn { background: #E85D2F; color: #fff; border-radius: 32rpx; font-size: 26rpx; border: none; padding: 12rpx 32rpx; }
.review-item { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 16rpx; }
.review-top { display: flex; justify-content: space-between; margin-bottom: 12rpx; }
.review-stars { color: #F59E0B; font-size: 24rpx; }
.review-date { font-size: 22rpx; color: #9CA3AF; }
.review-content { font-size: 28rpx; color: #4B5563; line-height: 1.7; }
.reply { background: #F9FAFB; padding: 20rpx; border-radius: 12rpx; margin-top: 16rpx; font-size: 26rpx; color: #6B7280; line-height: 1.6; }
.reply-label { color: #1F5FA8; font-weight: 600; }
