<view class="container" wx:if="{{userInfo}}">
  <!-- 头像 -->
  <view class="avatar-section card" bindtap="onChooseAvatar">
    <text class="label">头像</text>
    <view class="avatar-right">
      <view class="avatar-small">
        <image wx:if="{{userInfo.avatar}}" src="{{userInfo.avatar}}" mode="aspectFill" />
        <text wx:else class="avatar-text">{{userInitial}}</text>
      </view>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 用户名 -->
  <view class="info-item card">
    <text class="label">用户名</text>
    <text class="value">{{userInfo.username}}</text>
  </view>

  <!-- 昵称 -->
  <view class="info-item card">
    <text class="label">昵称</text>
    <input wx:if="{{editing}}" class="input" value="{{nickname}}" bindinput="onNicknameInput" placeholder="请输入昵称" />
    <text wx:else class="value">{{userInfo.nickname || '未设置'}}</text>
  </view>

  <!-- 手机号 -->
  <view class="info-item card">
    <text class="label">手机号</text>
    <input wx:if="{{editing}}" class="input" value="{{phone}}" bindinput="onPhoneInput" placeholder="请输入手机号" type="number" maxlength="11" />
    <text wx:else class="value">{{userInfo.phone || '未设置'}}</text>
  </view>

  <!-- 操作按钮 -->
  <view class="btn-group" wx:if="{{editing}}">
    <button class="btn-cancel" bindtap="onCancel">取消</button>
    <button class="btn-save" bindtap="onSave">保存</button>
  </view>
  <button wx:else class="edit-btn" bindtap="onEdit">编辑资料</button>

  <!-- 修改密码 -->
  <view class="password-btn card" bindtap="onShowPasswordModal">修改密码</view>

  <!-- 密码弹窗 -->
  <view class="modal-mask" wx:if="{{showPasswordModal}}" bindtap="onHidePasswordModal">
    <view class="modal" catchtap="">
      <view class="modal-title">修改密码</view>
      <input class="modal-input" type="text" password placeholder="原密码" value="{{oldPassword}}" bindinput="onOldPasswordInput" />
      <input class="modal-input" type="text" password placeholder="新密码（至少6位）" value="{{newPassword}}" bindinput="onNewPasswordInput" />
      <input class="modal-input" type="text" password placeholder="确认新密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
      <view class="modal-btns">
        <button class="modal-cancel" bindtap="onHidePasswordModal">取消</button>
        <button class="modal-confirm" bindtap="onChangePassword">确认</button>
      </view>
    </view>
  </view>
</view>
