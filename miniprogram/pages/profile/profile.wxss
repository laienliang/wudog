.avatar-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
}

.avatar-right {
  display: flex;
  align-items: center;
}

.avatar-small {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #c9a96e;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  overflow: hidden;
}

.avatar-small image {
  width: 100%;
  height: 100%;
}

.avatar-text {
  font-size: 32rpx;
  color: #fff;
}

.label {
  font-size: 30rpx;
  color: #333;
}

.value {
  font-size: 28rpx;
  color: #999;
}

.arrow {
  color: #999;
  font-size: 28rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
}

.input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn-cancel {
  flex: 1;
  background: #fff;
  color: #333;
  border: 1rpx solid #d9d9d9;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.btn-save {
  flex: 1;
  background: #c9a96e;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.edit-btn {
  margin-top: 30rpx;
  background: #c9a96e;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.password-btn {
  margin-top: 20rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 30rpx;
  color: #333;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal {
  width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-input {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.modal-cancel {
  flex: 1;
  background: #f5f5f5;
  color: #333;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.modal-confirm {
  flex: 1;
  background: #c9a96e;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
}
