.banner {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  padding: 40rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.banner-title {
  font-size: 36rpx;
  font-weight: 700;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
}

.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.category-picker {
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
  white-space: nowrap;
}

.product-item {
  display: flex;
  padding: 20rpx;
}

.product-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-category {
  font-size: 22rpx;
  color: #c9a96e;
  background: rgba(201,169,110,0.1);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  align-self: flex-start;
}

.product-price {
  font-size: 34rpx;
  color: #f5222d;
  font-weight: 600;
}

.product-stock {
  font-size: 22rpx;
  color: #999;
}
