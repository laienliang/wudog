.page { padding: 16rpx; padding-bottom: 120rpx; }

/* 顶栏 */
.top-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 10rpx 0 16rpx; gap: 16rpx;
}
.search-box {
  flex: 1; display: flex; align-items: center; gap: 10rpx;
  background: #f5f5f5; border-radius: 36rpx; padding: 14rpx 24rpx;
}
.search-icon { font-size: 28rpx; }
.search-placeholder { font-size: 26rpx; color: #999; }
.mine-btn {
  font-size: 26rpx; color: #1677ff; font-weight: 600;
  padding: 14rpx 24rpx; background: #e6f4ff; border-radius: 36rpx;
  white-space: nowrap;
}

/* 话题 */
.topic-bar { white-space: nowrap; padding: 8rpx 0; margin-bottom: 16rpx; }
.topic-tag {
  display: inline-block; padding: 8rpx 24rpx; margin-right: 12rpx;
  border-radius: 24rpx; font-size: 26rpx;
  background: #f0f0f0; color: #666;
}
.topic-tag.active { background: #1677ff; color: #fff; }

.empty { text-align: center; padding: 160rpx 0; color: #999; font-size: 28rpx; }
.list { display: flex; flex-direction: column; gap: 16rpx; }
.loading, .no-more { text-align: center; padding: 20rpx; color: #999; font-size: 24rpx; }

/* 发布 FAB */
.fab {
  position: fixed; bottom: 80rpx; right: 40rpx;
  width: 100rpx; height: 100rpx; background: #1677ff; color: #fff;
  border-radius: 50%; text-align: center; line-height: 100rpx; font-size: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(22,119,255,0.4); z-index: 99;
}
