/* pages/index/index.wxss - 列表页样式 */
.container {
  padding: 20rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.search-btn {
  margin-left: 16rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 30rpx;
  background: #165DFF;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
}

/* 筛选栏 */
.filter-bar {
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.filter-item {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.arrow {
  margin-left: 10rpx;
  font-size: 20rpx;
  color: #999;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 列表 */
.list {
  padding-bottom: 20rpx;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.card-img {
  width: 100%;
  height: 360rpx;
}

.card-info {
  padding: 20rpx 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #86909C;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-price {
  font-size: 32rpx;
  color: #F53F3F;
  font-weight: bold;
}

.card-rating {
  font-size: 24rpx;
  color: #FF7D00;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx 0;
  color: #165DFF;
  font-size: 28rpx;
}

.no-more {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 28rpx;
}
