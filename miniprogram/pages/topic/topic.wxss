.page { padding: 20rpx; }
.topic-header {
  background: linear-gradient(135deg, #1677ff, #764ba2); color: #fff;
  padding: 40rpx 32rpx; border-radius: 16rpx; margin-bottom: 24rpx;
}
.topic-name { font-size: 40rpx; font-weight: bold; margin-bottom: 8rpx; }
.topic-desc { font-size: 28rpx; opacity: 0.9; margin-bottom: 16rpx; }
.topic-stats { display: flex; gap: 30rpx; font-size: 26rpx; }
.empty, .loading, .no-more { text-align: center; padding: 40rpx; color: #999; font-size: 28rpx; }
