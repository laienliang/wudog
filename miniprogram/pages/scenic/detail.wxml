<!--pages/scenic/detail.wxml-->
<view class="container">
  <view class="back-nav" bindtap="goBack">← 返回</view>

  <view class="detail-section" wx:if="{{spot}}">
    <image class="cover" src="{{spot.coverImage}}" mode="aspectFill" />
    <view class="title">{{spot.name}}</view>
    <view class="info">📍 {{spot.address}}</view>
    <view class="desc">{{spot.description || ''}}</view>
  </view>

  <view class="detail-section" wx:if="{{ticketTypes.length > 0}}">
    <view class="section-title">可选票种</view>
    <block wx:for="{{ticketTypes}}" wx:key="id">
      <view class="ticket-item">
        <view class="info">
          <view class="name">{{item.name}}</view>
          <view class="desc">有效{{item.validDays}}天 · {{item.description || ''}}</view>
        </view>
        <view class="price">¥{{item.sellPrice}}</view>
        <view>
          <button class="btn btn-primary btn-small" bindtap="buyTicket" data-id="{{item.id}}" data-name="{{item.name}}" data-price="{{item.sellPrice}}">购买</button>
        </view>
      </view>
    </block>
  </view>
</view>
