.logo-area {
  text-align: center;
  padding: 80rpx 0 60rpx;
}

.logo {
  font-size: 64rpx;
  font-weight: 700;
  color: #c9a96e;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
  margin-top: 12rpx;
}

.form {
  padding: 40rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item input {
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.submit-btn {
  background: #c9a96e;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
}

.submit-btn[disabled] {
  background: #ccc;
}

.switch-btn {
  text-align: center;
  color: #c9a96e;
  font-size: 26rpx;
  margin-top: 24rpx;
}
