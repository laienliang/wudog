.page {
  display: flex; justify-content: center; align-items: center;
  min-height: 100vh; background: linear-gradient(135deg, #1677ff 0%, #764ba2 100%);
}
.card {
  width: 600rpx; background: #fff; border-radius: 20rpx;
  padding: 60rpx 50rpx; box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
}
.title { text-align: center; font-size: 44rpx; font-weight: bold; color: #333; margin-bottom: 8rpx; }
.subtitle { text-align: center; font-size: 26rpx; color: #999; margin-bottom: 60rpx; }
.input {
  width: 100%; padding: 24rpx 20rpx; margin-bottom: 24rpx;
  border: 1rpx solid #e0e0e0; border-radius: 12rpx; font-size: 30rpx;
  background: #f9f9f9; box-sizing: border-box;
}
.login-btn {
  width: 100%; margin-top: 20rpx; border-radius: 12rpx; font-size: 32rpx;
  background: #1677ff;
}
.hint { text-align: center; font-size: 24rpx; color: #ccc; margin-top: 30rpx; }
