<view class="page">
  <view class="card">
    <view class="title">乌东文旅</view>
    <view class="subtitle">社区分享</view>

    <input class="input" placeholder="用户名" value="{{username}}" bindinput="onUsernameInput" />
    <input class="input" placeholder="密码" type="password" value="{{password}}" bindinput="onPasswordInput" />

    <button class="login-btn" type="primary" bindtap="onLogin" loading="{{loading}}">
      登录
    </button>

    <view class="hint">测试账号：admin / admin123</view>
  </view>
</view>
