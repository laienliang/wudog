.page { padding: 24rpx; }
.form { background: #fff; border-radius: 12rpx; padding: 28rpx; }
.title-input { font-size: 34rpx; margin-bottom: 20rpx; padding: 16rpx 0; border-bottom: 1rpx solid #eee; }
.content-input { width: 100%; min-height: 400rpx; font-size: 30rpx; margin-bottom: 20rpx; }

/* 图片 */
.image-section { margin-bottom: 20rpx; }
.image-label { font-size: 28rpx; color: #666; margin-bottom: 12rpx; }
.image-grid { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 16rpx; }
.image-item { position: relative; width: 156rpx; height: 156rpx; border-radius: 8rpx; overflow: hidden; }
.image-thumb { width: 100%; height: 100%; }
.image-remove { position: absolute; top: 0; right: 0; width: 36rpx; height: 36rpx; background: rgba(0,0,0,0.5); color: #fff; font-size: 24rpx; text-align: center; line-height: 36rpx; border-radius: 0 8rpx 0 8rpx; }
.image-index { position: absolute; bottom: 0; left: 0; background: rgba(0,0,0,0.5); color: #fff; font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 0 6rpx 0 0; }
.upload-actions { display: flex; flex-direction: column; gap: 12rpx; }
.upload-btn { font-size: 26rpx; padding: 12rpx 0; background: #f0f7ff; color: #1677ff; border: 1rpx dashed #1677ff; border-radius: 8rpx; }
.upload-btn[disabled] { opacity: 0.5; }
.url-row { display: flex; gap: 8rpx; align-items: center; }
.url-input { flex: 1; font-size: 26rpx; padding: 12rpx 16rpx; border: 1rpx solid #e0e0e0; border-radius: 8rpx; }
.url-btn { font-size: 24rpx; padding: 12rpx 24rpx; background: #1677ff; color: #fff; border-radius: 8rpx; white-space: nowrap; }
.url-btn[disabled] { background: #ccc; }

.picker { display: flex; align-items: center; padding: 24rpx 0; border-top: 1rpx solid #eee; color: #666; font-size: 28rpx; }
.picker-val { color: #999; margin-left: 8rpx; }
.picker-arrow { margin-left: auto; font-size: 36rpx; color: #ccc; }
.btns { display: flex; gap: 20rpx; margin-top: 40rpx; }
.btns button { flex: 1; }
