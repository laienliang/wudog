<view class="container">
  <view class="cart-list" wx:if="{{cartItems.length > 0}}">
    <view class="cart-item card" wx:for="{{cartItems}}" wx:key="id">
      <view class="item-check" bindtap="onCheck" data-index="{{index}}">
        <view class="checkbox {{item.checked ? 'checked' : ''}}">✓</view>
      </view>
      <image class="item-image" src="{{item.imageUrl}}" mode="aspectFill" />
      <view class="item-info">
        <view class="item-name">{{item.productName}}</view>
        <view class="item-spec">{{item.specName}}</view>
        <view class="item-stock">库存:{{item.stock}}</view>
        <view class="item-bottom">
          <text class="item-price">¥{{item.price}}</text>
          <view class="quantity-control">
            <view class="qty-btn" bindtap="onQuantityChange" data-index="{{index}}" data-type="minus">-</view>
            <text class="qty-num">{{item.quantity}}</text>
            <view class="qty-btn {{item.quantity >= item.stock ? 'qty-btn-disabled' : ''}}" bindtap="onQuantityChange" data-index="{{index}}" data-type="add">+</view>
          </view>
        </view>
      </view>
      <view class="item-delete" bindtap="onDelete" data-index="{{index}}">删除</view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!loading && cartItems.length === 0}}">购物车是空的</view>
  <view class="loading-state" wx:if="{{loading}}">加载中...</view>

  <!-- 底部结算栏 -->
  <view class="bottom-bar" wx:if="{{cartItems.length > 0}}">
    <view class="total-info">
      <text>合计：</text>
      <text class="total-price">¥{{totalPrice}}</text>
    </view>
  </view>
</view>
