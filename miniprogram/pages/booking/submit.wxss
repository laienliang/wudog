.page-container { padding: 24rpx; min-height: 100vh; background: #F5F7FA; }
.card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 24rpx; }
.card-title { font-size: 34rpx; font-weight: 700; color: #fff; margin-bottom: 12rpx; }
.room-card { background: linear-gradient(135deg, #1F5FA8, #0D3B6E); }
.card-price { font-size: 28rpx; color: rgba(255,255,255,0.9); }
.section-label { font-size: 30rpx; font-weight: 600; color: #1F5FA8; margin-bottom: 20rpx; }
.picker-row { border: 2rpx solid #E5E7EB; border-radius: 12rpx; padding: 22rpx; font-size: 28rpx; color: #1A1A2E; margin-bottom: 20rpx; }
.nights-info { text-align: right; padding: 8rpx 0; color: #6B7280; font-size: 28rpx; }
.nights-num { color: #1F5FA8; font-weight: 700; }
.form-input { border: 2rpx solid #E5E7EB; border-radius: 12rpx; padding: 22rpx; font-size: 28rpx; margin-bottom: 20rpx; }
.form-input.short { width: 120rpx; text-align: center; }
.form-row { display: flex; align-items: center; justify-content: space-between; padding: 10rpx 0; font-size: 28rpx; }
.submit-btn { width: 100%; margin-top: 32rpx; border-radius: 20rpx; padding: 28rpx; font-size: 34rpx; font-weight: 700; color: #fff; background: #E85D2F; border: none; }
.submit-btn[disabled] { background: #D1D5DB; }
.result-card { text-align: center; padding: 40rpx; }
.result-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.result-title { font-size: 40rpx; font-weight: 700; color: #10B981; margin-bottom: 16rpx; }
.result-row { font-size: 28rpx; color: #6B7280; margin-bottom: 8rpx; }
.code-box { background: #F0F8FF; border: 2rpx dashed #1F5FA8; border-radius: 16rpx; padding: 32rpx; margin-top: 24rpx; }
.code-label { font-size: 28rpx; color: #6B7280; margin-bottom: 16rpx; }
.code-value { font-size: 48rpx; font-weight: 900; letter-spacing: 8rpx; color: #1F5FA8; font-family: monospace; }
.code-tip { font-size: 24rpx; color: #9CA3AF; margin-top: 12rpx; }
