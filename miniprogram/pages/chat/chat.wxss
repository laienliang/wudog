.chat-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.messages {
  flex: 1;
  padding: 20rpx;
}

.empty-hint {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 28rpx;
}

.msg-item {
  margin-bottom: 20rpx;
  max-width: 80%;
}

.msg-left {
  margin-right: auto;
}

.msg-right {
  margin-left: auto;
}

.bubble {
  padding: 20rpx 28rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.bubble-left {
  background: #fff;
  color: #333;
  border-radius: 16rpx 16rpx 16rpx 4rpx;
}

.bubble-right {
  background: #c9a96e;
  color: #fff;
  border-radius: 16rpx 16rpx 4rpx 16rpx;
}

.msg-time {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 8rpx;
  display: block;
}

.msg-right .msg-time {
  text-align: right;
}

.input-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.chat-input {
  flex: 1;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.send-btn {
  background: #c9a96e;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.send-btn[disabled] {
  background: #ccc;
}
