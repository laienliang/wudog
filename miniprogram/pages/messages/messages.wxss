.page { padding: 0; }
.empty, .status { text-align: center; padding: 100rpx 40rpx; color: #999; font-size: 28rpx; }
.empty-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.msg-item { display: flex; gap: 16rpx; padding: 24rpx 30rpx; background: #fff; border-bottom: 1rpx solid #f5f5f5; }
.msg-icon { font-size: 40rpx; width: 60rpx; text-align: center; }
.msg-body { flex: 1; }
.msg-text { font-size: 28rpx; color: #333; margin-bottom: 8rpx; }
.msg-time { font-size: 24rpx; color: #bbb; }
