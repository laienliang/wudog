.detail-status { font-size:36rpx; font-weight:700; text-align:center; padding:32rpx 0; }
.dt-card { background:#fff; border-radius:16rpx; padding:24rpx; margin-bottom:24rpx; }
.dt-row { display:flex; justify-content:space-between; padding:16rpx 0; border-bottom:1rpx solid #F3F4F6; font-size:28rpx; }
.dt-label { color:#9CA3AF; }
.qr-card { background:#F0F8FF; border:2rpx dashed var(--color-primary); border-radius:16rpx; padding:32rpx; text-align:center; margin-bottom:24rpx; }
.qr-label { font-size:28rpx; color:#6B7280; margin-bottom:16rpx; }
.qr-code { font-size:52rpx; font-weight:900; letter-spacing:10rpx; color:var(--color-primary); font-family:'Courier New',monospace; }
.qr-tip { font-size:24rpx; color:#9CA3AF; margin-top:12rpx; }
.refund-info { background:#FFF7ED; border-radius:16rpx; padding:24rpx; text-align:center; font-size:30rpx; margin-bottom:24rpx; }
.btn-cancel-lg { width:100%; margin-top:24rpx; border:2rpx solid #EF4444; color:#EF4444; border-radius:16rpx; font-size:28rpx; background:#fff; }
.btn-pay-lg { width:100%; margin-top:24rpx; background:var(--color-primary); color:#fff; border-radius:16rpx; font-size:28rpx; border:none; }
.btn-review { width:100%; margin-top:24rpx; background:var(--color-primary); color:#fff; border-radius:16rpx; font-size:28rpx; border:none; }

/* 评价弹窗 */
.review-modal-mask { position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:1000; display:flex; align-items:center; justify-content:center; }
.review-modal { background:#fff; border-radius:20rpx; padding:40rpx; width:620rpx; }
.rm-title { font-size:34rpx; font-weight:700; text-align:center; margin-bottom:24rpx; }
.rm-stars { display:flex; justify-content:center; gap:16rpx; margin-bottom:24rpx; }
.rm-star { font-size:52rpx; color:#D1D5DB; }
.rm-star.active { color:#F59E0B; }
.rm-textarea { width:100%; height:200rpx; border:2rpx solid #E5E7EB; border-radius:12rpx; padding:20rpx; font-size:28rpx; box-sizing:border-box; }
.rm-btns { display:flex; gap:20rpx; margin-top:24rpx; }
.rm-btn-cancel { flex:1; border:2rpx solid #E5E7EB; border-radius:12rpx; font-size:28rpx; background:#fff; }
.rm-btn-submit { flex:1; background:var(--color-primary); color:#fff; border-radius:12rpx; font-size:28rpx; border:none; }
