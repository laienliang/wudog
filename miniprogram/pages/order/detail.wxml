<!-- 订单详情页 -->
<view class="page-container" wx:if="{{order}}">
  <view class="detail-status" style="color:{{statusMap[order.status].color}}">{{statusMap[order.status].label}}</view>

  <view class="dt-card">
    <view class="dt-row"><text class="dt-label">订单号</text><text>{{order.order_no}}</text></view>
    <view class="dt-row"><text class="dt-label">入住日期</text><text>{{order.check_in_date}}</text></view>
    <view class="dt-row"><text class="dt-label">离店日期</text><text>{{order.check_out_date}}</text></view>
    <view class="dt-row"><text class="dt-label">入住晚数</text><text>{{order.nights}} 晚</text></view>
    <view class="dt-row"><text class="dt-label">预订间数</text><text>{{order.room_count}} 间</text></view>
    <view class="dt-row"><text class="dt-label">入住人</text><text>{{order.contact_name}}</text></view>
    <view class="dt-row"><text class="dt-label">联系电话</text><text>{{order.contact_phone}}</text></view>
    <view class="dt-row"><text class="dt-label">入住人数</text><text>{{order.guest_count}} 人</text></view>
    <view class="dt-row"><text class="dt-label">总价</text><text class="price">¥{{order.total_price}}</text></view>
  </view>

  <view wx:if="{{order.check_in_code}}" class="qr-card">
    <view class="qr-label">🏨 入住核销码</view>
    <view class="qr-code">{{order.check_in_code}}</view>
    <view class="qr-tip">入住时请向前台出示此码</view>
  </view>

  <view wx:if="{{order.refund_amount > 0}}" class="refund-info">
    退款金额：<text class="price">¥{{order.refund_amount}}</text>
  </view>

  <button wx:if="{{order.status === 0}}" class="btn-pay-lg" bindtap="onPay">💰 立即支付（模拟）</button>

  <button wx:if="{{order.status === 0 || order.status === 1 || order.status === 2}}"
    class="btn-cancel-lg" bindtap="onCancel">取消订单</button>

  <button wx:if="{{order.status === 4}}" class="btn-review" bindtap="onOpenReview">✍️ 写评价</button>
</view>

<!-- 评价弹窗 -->
<view wx:if="{{showReview}}" class="review-modal-mask" bindtap="onCloseReview">
  <view class="review-modal" catchtap="">
    <view class="rm-title">写评价</view>
    <view class="rm-stars">
      <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this"
        class="rm-star {{item <= reviewRating ? 'active' : ''}}"
        bindtap="onRatingTap" data-rating="{{item}}">{{item <= reviewRating ? '★' : '☆'}}</text>
    </view>
    <textarea class="rm-textarea" placeholder="分享你的入住体验..." value="{{reviewContent}}" bindinput="onReviewInput" maxlength="500" />
    <view class="rm-btns">
      <button class="rm-btn-cancel" bindtap="onCloseReview">取消</button>
      <button class="rm-btn-submit" bindtap="onSubmitReview" loading="{{submittingReview}}">提交评价</button>
    </view>
  </view>
</view>
