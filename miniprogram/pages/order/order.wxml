<!--pages/order/order.wxml - 下单页-->
<view class="container">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <block wx:elif="{{accommodation && room}}">
    <!-- 订单信息 -->
    <view class="order-info">
      <view class="info-title">{{accommodation.name}}</view>
      <view class="info-room">房型：{{room.name}}</view>
      <view class="info-date">
        <text>入住：{{checkInDate}}</text>
        <text>离店：{{checkOutDate}}</text>
      </view>
      <view class="info-nights">共{{nights}}晚</view>
      <view class="info-price">
        <text>总价：</text>
        <text class="price-value">¥{{totalPrice}}</text>
      </view>
    </view>

    <!-- 入住人信息 -->
    <view class="form-section">
      <view class="form-title">入住人信息</view>
      <view class="form-item">
        <text class="form-label">姓名</text>
        <input class="form-input" placeholder="请输入入住人姓名" value="{{guestName}}" bindinput="onGuestNameInput" />
      </view>
      <view class="form-item">
        <text class="form-label">手机号</text>
        <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{guestPhone}}" bindinput="onGuestPhoneInput" />
      </view>
    </view>

    <!-- 备注 -->
    <view class="form-section">
      <view class="form-title">备注</view>
      <textarea class="form-textarea" placeholder="如有特殊需求请在此说明" value="{{remark}}" bindinput="onRemarkInput" />
    </view>

    <!-- 提交按钮 -->
    <view class="submit-bar">
      <button class="submit-btn" bindtap="submitOrder" disabled="{{submitting}}">
        {{submitting ? '提交中...' : '提交订单'}}
      </button>
    </view>
  </block>

  <!-- 空状态 -->
  <view wx:else class="empty">
    <text>数据加载失败</text>
  </view>
</view>
