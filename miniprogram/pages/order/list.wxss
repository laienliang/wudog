/* 订单列表样式 */
.tab-bar { white-space:nowrap; margin-bottom:24rpx; }
.tab-item { display:inline-block; padding:16rpx 32rpx; border-radius:32rpx; margin-right:16rpx; font-size:26rpx; background:#fff; color:#6B7280; }
.tab-item.active { background:var(--color-primary); color:#fff; }
.order-card { background:#fff; border-radius:16rpx; padding:24rpx; margin-bottom:20rpx; box-shadow:0 2rpx 8rpx rgba(0,0,0,0.04); }
.order-header { display:flex; justify-content:space-between; margin-bottom:16rpx; }
.order-no { font-size:24rpx; color:#9CA3AF; }
.order-status { font-size:26rpx; font-weight:600; }
.order-body { }
.order-dates, .order-guest, .order-price { font-size:26rpx; margin-bottom:8rpx; }
.order-nights { color:#9CA3AF; margin-left:8rpx; }
.order-code { margin-top:8rpx; font-size:26rpx; }
.order-actions { margin-top:16rpx; text-align:right; }
.btn-cancel { border:2rpx solid #EF4444; color:#EF4444; border-radius:32rpx; background:#fff; font-size:24rpx; }
.btn-pay { border:2rpx solid var(--color-primary); color:#fff; border-radius:32rpx; background:var(--color-primary); font-size:24rpx; margin-right:16rpx; }
