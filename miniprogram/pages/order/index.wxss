.order-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.status-pending { color: #1677ff; background: #e6f0ff; }
.status-used { color: #52c41a; background: #f6ffed; }
.status-cancelled { color: #faad14; background: #fffbe6; }
.status-expired { color: #ff4d4f; background: #fff2f0; }

/* 购票模式样式 */
.back-btn {
  font-size: 28rpx;
  color: #1677ff;
  padding: 12rpx 0;
  cursor: pointer;
}

.buy-tabs {
  display: flex;
  gap: 16rpx;
  margin: 16rpx 0;
}
.buy-tab {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
  background: #f5f5f5;
  color: #666;
}
.buy-tab.active {
  background: #1677ff;
  color: #fff;
}

.item-list {
  max-height: 600rpx;
  overflow-y: auto;
}
.item-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  margin-bottom: 8rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}
.item-card.selected {
  background: #e8f4fd;
  border: 1rpx solid #1677ff;
}
.item-name {
  font-size: 28rpx;
  flex: 1;
}
.item-price {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.empty-hint {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
}

.buy-form {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}
.form-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.form-row text {
  font-size: 28rpx;
  color: #333;
}
.form-input {
  width: 200rpx;
  height: 60rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  text-align: right;
}
.total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 20rpx 0;
  font-size: 30rpx;
}
.total-price {
  color: #ff4d4f;
  font-weight: bold;
  font-size: 36rpx;
}
