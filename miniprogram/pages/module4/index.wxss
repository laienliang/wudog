.container { min-height: 100vh; background: #f5f5f5; padding-bottom: 20rpx; }
.tab-bar { display: flex; background: #fff; padding: 20rpx; }
.tab { flex: 1; text-align: center; padding: 16rpx; font-size: 28rpx; color: #666; border-bottom: 4rpx solid transparent; }
.tab-active { color: #1677ff; border-bottom-color: #1677ff; font-weight: 600; }

.spot-card { background: #fff; margin: 20rpx; border-radius: 12rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.card-img { width: 100%; height: 340rpx; }
.card-info { padding: 20rpx; }
.card-name { font-size: 32rpx; font-weight: 600; }
.card-addr { font-size: 24rpx; color: #999; margin-top: 6rpx; }
.card-time { font-size: 24rpx; color: #666; margin-top: 6rpx; }
.card-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 12rpx; }
.theme-tag { display: inline-block; padding: 2rpx 12rpx; background: #e6f7ff; color: #1677ff; border-radius: 4rpx; font-size: 22rpx; margin-right: 8rpx; }
.days { font-size: 24rpx; color: #666; }
.price { font-size: 32rpx; color: #e74c3c; font-weight: 600; }

.loading { text-align: center; padding: 60rpx; color: #999; }
.empty { text-align: center; padding: 60rpx; color: #999; font-size: 28rpx; }
