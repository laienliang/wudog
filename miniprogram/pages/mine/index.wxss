.page { padding: 20rpx; padding-bottom: 40rpx; }

/* 用户卡片 */
.profile-card {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 20rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  color: #fff;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.3);
}
.avatar {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 16rpx;
  font-size: 40rpx; font-weight: bold;
}
.nickname { font-size: 36rpx; font-weight: bold; margin-bottom: 20rpx; }
.stats { display: flex; justify-content: center; gap: 40rpx; margin-bottom: 28rpx; font-size: 26rpx; opacity: 0.9; }
.stat { }

.publish-btn {
  display: inline-block; width: 240rpx; padding: 18rpx 0;
  background: #fff; color: #667eea; border: none; border-radius: 40rpx;
  font-size: 30rpx; font-weight: 600; line-height: 1; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

/* 快捷入口 */
.quick-links {
  display: flex; gap: 16rpx; margin-bottom: 20rpx;
}
.link-item {
  flex: 1; background: #fff; border-radius: 16rpx;
  padding: 20rpx 8rpx; text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.link-icon { font-size: 40rpx; margin-bottom: 8rpx; }
.link-text { font-size: 22rpx; color: #666; }

/* Tab */
.tabs { display: flex; background: #fff; border-radius: 14rpx; padding: 6rpx; margin-bottom: 20rpx; }
.tab {
  flex: 1; text-align: center; padding: 20rpx 0; border-radius: 12rpx;
  font-size: 28rpx; color: #666; transition: all 0.2s;
}
.tab.active { background: #1677ff; color: #fff; font-weight: 600; }

/* 筛选 */
.filter-bar {
  display: flex; gap: 12rpx; margin-bottom: 20rpx; flex-wrap: wrap;
}
.filter-tag {
  padding: 10rpx 28rpx; border-radius: 28rpx;
  border: 1rpx solid #e0e0e0; background: #fff; color: #666;
  font-size: 24rpx;
}
.filter-tag.active { background: #1677ff; color: #fff; border-color: #1677ff; }

/* 空状态 */
.empty { text-align: center; padding: 80rpx 40rpx; }
.empty-icon { display: block; font-size: 80rpx; margin-bottom: 20rpx; }
.empty { color: #999; font-size: 28rpx; }
.empty-btn {
  display: inline-block; margin-top: 30rpx; padding: 18rpx 50rpx;
  background: #1677ff; color: #fff; border: none; border-radius: 36rpx;
  font-size: 28rpx;
}
.status-tip { text-align: center; padding: 60rpx; color: #999; font-size: 28rpx; }

/* 游记项 */
.note-item {
  display: flex; gap: 20rpx; background: #fff; border-radius: 16rpx;
  padding: 20rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.note-img { width: 140rpx; height: 110rpx; border-radius: 12rpx; flex-shrink: 0; }
.note-img-placeholder { background: linear-gradient(135deg, #667eea, #764ba2); }
.note-body { flex: 1; min-width: 0; display: flex; flex-direction: column; }
.note-title {
  font-size: 30rpx; font-weight: 600; color: #333;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 8rpx;
}
.note-meta { font-size: 22rpx; color: #999; margin-bottom: 8rpx; display: flex; gap: 8rpx; }
.note-status {
  display: inline-block; align-self: flex-start;
  padding: 2rpx 14rpx; border-radius: 8rpx; font-size: 20rpx;
}
.status-draft { color: #faad14; background: #fffbe6; }
.status-reviewing { color: #1677ff; background: #e6f4ff; }
.status-published { color: #52c41a; background: #f6ffed; }
.status-rejected { color: #ff4d4f; background: #fff2f0; }
.reject-reason { font-size: 22rpx; color: #ff4d4f; margin-top: 6rpx; }
.note-actions { display: flex; gap: 12rpx; margin-top: 10rpx; flex-wrap: wrap; }
.action {
  padding: 6rpx 16rpx; border-radius: 8rpx; font-size: 22rpx;
  background: #f5f5f5; color: #666;
}
.action.primary { background: #e6f4ff; color: #1677ff; }
.action.danger { background: #fff2f0; color: #ff4d4f; }

.unfav-btn {
  align-self: center; padding: 8rpx 20rpx; border-radius: 8rpx;
  border: 1rpx solid #ffccc7; color: #ff4d4f; font-size: 22rpx; flex-shrink: 0;
}
