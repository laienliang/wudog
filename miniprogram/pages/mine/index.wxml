<!--pages/mine/index.wxml-->
<view class="container">
  <view class="profile" wx:if="{{loggedIn}}">
    <view class="avatar-placeholder"></view>
    <view class="nickname">游客用户</view>
    <view class="desc">ID: {{userId}}</view>
  </view>
  <view class="profile" wx:else>
    <view class="login-btn btn btn-primary" bindtap="login">微信登录</view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="toOrders">
      <text>我的订单</text>
      <text style="color: #ccc;">›</text>
    </view>
  </view>
</view>
