<view class="page">
  <!-- 用户信息 -->
  <view class="profile-card">
    <view class="avatar">{{username ? username[0] : 'U'}}</view>
    <view class="nickname">{{username || '用户'}}</view>
    <view class="stats">
      <text class="stat">游记 {{stats.noteCount}}</text>
      <text class="stat">已发布 {{stats.publishedCount}}</text>
      <text class="stat">收藏 {{favorites.length}}</text>
    </view>
    <button class="publish-btn" bindtap="goEdit">+ 写游记</button>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-links">
    <view class="link-item" bindtap="goOrders" data-path="/pages/module3/orders">
      <view class="link-icon">🏠</view>
      <text class="link-text">民宿订单</text>
    </view>
    <view class="link-item" bindtap="goOrders" data-path="/pages/module4/orders">
      <view class="link-icon">🎫</view>
      <text class="link-text">出行订单</text>
    </view>
    <view class="link-item" bindtap="goOrders" data-path="/pages/cart/cart">
      <view class="link-icon">🛒</view>
      <text class="link-text">购物车</text>
    </view>
    <view class="link-item" bindtap="goOrders" data-path="/pages/module2/bookings">
      <view class="link-icon">🍽</view>
      <text class="link-text">餐饮预订</text>
    </view>
  </view>

  <!-- Tab -->
  <view class="tabs">
    <view class="tab {{tab === 'notes' ? 'active' : ''}}" data-key="notes" bindtap="onTab">我的游记</view>
    <view class="tab {{tab === 'favorites' ? 'active' : ''}}" data-key="favorites" bindtap="onTab">我的收藏</view>
  </view>

  <!-- 状态筛选 -->
  <view wx:if="{{tab === 'notes'}}" class="filter-bar">
    <text class="filter-tag {{statusFilter === '' ? 'active' : ''}}" data-status="" bindtap="onStatusFilter">全部</text>
    <text class="filter-tag {{statusFilter === 'draft' ? 'active' : ''}}" data-status="draft" bindtap="onStatusFilter">草稿</text>
    <text class="filter-tag {{statusFilter === 'reviewing' ? 'active' : ''}}" data-status="reviewing" bindtap="onStatusFilter">审核中</text>
    <text class="filter-tag {{statusFilter === 'published' ? 'active' : ''}}" data-status="published" bindtap="onStatusFilter">已发布</text>
    <text class="filter-tag {{statusFilter === 'rejected' ? 'active' : ''}}" data-status="rejected" bindtap="onStatusFilter">已驳回</text>
  </view>

  <!-- 内容区 -->
  <view wx:if="{{loading}}" class="status-tip">加载中...</view>

  <block wx:elif="{{tab === 'notes'}}">
    <view wx:if="{{notes.length === 0}}" class="empty">
      <text class="empty-icon">📝</text>
      <text>{{statusFilter ? '暂无该状态的游记' : '还没有游记'}}</text>
      <button class="empty-btn" bindtap="goEdit">发布第一篇游记</button>
    </view>

    <view wx:for="{{notes}}" wx:key="id" class="note-item">
      <image wx:if="{{item.images && item.images[0]}}" class="note-img" src="{{item.images[0]}}" mode="aspectFill" />
      <view wx:else class="note-img note-img-placeholder"></view>
      <view class="note-body">
        <text class="note-title" bindtap="goDetail" data-id="{{item.id}}">{{item.title}}</text>
        <view class="note-meta">
          <text>{{item.created_at}}</text>
          <text> | 浏览 {{item.viewCount || 0}}</text>
        </view>
        <text class="note-status status-{{item.status}}">{{item.statusLabel}}</text>
        <text wx:if="{{item.status === 'rejected' && item.rejectReason}}" class="reject-reason">驳回原因：{{item.rejectReason}}</text>
        <view class="note-actions">
          <text wx:if="{{item.status === 'published'}}" class="action" bindtap="goDetail" data-id="{{item.id}}">查看</text>
          <text wx:if="{{item.status === 'draft' || item.status === 'rejected'}}" class="action primary" bindtap="goEditNote" data-id="{{item.id}}">编辑</text>
          <text wx:if="{{item.status === 'draft' || item.status === 'rejected'}}" class="action primary" bindtap="handleSubmit" data-id="{{item.id}}">提交审核</text>
          <text class="action danger" bindtap="handleDelete" data-id="{{item.id}}">删除</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:elif="{{tab === 'favorites'}}">
    <view wx:if="{{favorites.length === 0}}" class="empty">
      <text class="empty-icon">⭐</text>
      <text>还没有收藏游记</text>
    </view>

    <view wx:for="{{favorites}}" wx:key="id" class="note-item">
      <image wx:if="{{item.note && item.note.images && item.note.images[0]}}" class="note-img" src="{{item.note.images[0]}}" mode="aspectFill" />
      <view wx:else class="note-img note-img-placeholder"></view>
      <view class="note-body">
        <text class="note-title" bindtap="goDetail" data-id="{{item.note ? item.note.id : item.noteId}}">{{item.note ? item.note.title : '无标题'}}</text>
        <view class="note-meta">
          <text wx:if="{{item.note}}">{{item.note.created_at}}</text>
        </view>
      </view>
      <view class="unfav-btn" bindtap="handleUnfavorite" data-id="{{item.note ? item.note.id : item.noteId}}">取消</view>
    </view>
  </block>
</view>
