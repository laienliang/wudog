/* pages/order-list/order-list.wxss */
.container {
  min-height: 100vh;
  background: #f5f7fa;
}

/* ===== Tab 栏 ===== */
.tab-scroll {
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-bar {
  display: flex;
  padding: 0 16rpx;
  white-space: nowrap;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 24rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
  flex-shrink: 0;
}

.tab-item.active {
  color: #165DFF;
  font-weight: bold;
  font-size: 30rpx;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #165DFF;
}

/* ===== 加载 & 空状态 ===== */
.loading-wrap, .empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  color: #999;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
  margin-bottom: 40rpx;
}

.empty-btn {
  background: #165DFF;
  color: #fff;
  font-size: 28rpx;
  padding: 12rpx 60rpx;
  border-radius: 40rpx;
}

/* ===== 订单卡片 ===== */
.order-list {
  padding: 20rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.order-no {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.order-date {
  font-size: 22rpx;
  color: #ccc;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  white-space: nowrap;
}

/* 卡片内容 */
.card-body {
  padding: 28rpx;
}

.accommodation-info {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.acc-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 12rpx;
}

.room-name {
  font-size: 26rpx;
  color: #888;
  background: #f5f5f5;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.date-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.date-text {
  font-size: 26rpx;
  color: #666;
}

.nights-text {
  font-size: 24rpx;
  color: #fa8c16;
  font-weight: 500;
}

.guest-row {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 16rpx;
}

.price-row {
  display: flex;
  justify-content: flex-end;
  align-items: baseline;
}

.total-price {
  font-size: 36rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.total-price::before {
  content: '合计 ';
  font-size: 26rpx;
  color: #666;
  font-weight: normal;
}

/* 卡底部操作区 */
.card-footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 20rpx 28rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 16rpx;
}

.btn {
  font-size: 26rpx;
  padding: 10rpx 30rpx;
  border-radius: 36rpx;
  line-height: 1.6;
  margin: 0 !important;
  background: none;

  /* 去除小程序默认按钮样式 */
  position: relative;
}

.btn::after {
  border: none;
}

.btn-default {
  color: #666;
  border: 1rpx solid #d9d9d9;
  background: #fff;
}

.btn-primary {
  color: #fff;
  background: #165DFF;
  border: 1rpx solid #165DFF;
}

.btn-primary-outline {
  color: #165DFF;
  border: 1rpx solid #165DFF;
  background: #e6f4ff;
}

.btn-success {
  color: #fff;
  background: #52c41a;
  border: 1rpx solid #52c41a;
}
