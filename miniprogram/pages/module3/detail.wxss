.container { min-height: 100vh; background: #f5f5f5; }
.main-img { width: 100%; height: 400rpx; }
.info-card { background: #fff; padding: 24rpx; margin-bottom: 16rpx; }
.name { font-size: 36rpx; font-weight: 600; }
.addr { font-size: 26rpx; color: #999; margin-top: 8rpx; }
.tags { margin-top: 10rpx; }
.tag { display: inline-block; padding: 2rpx 12rpx; margin-right: 8rpx; background: #e6f7ff; color: #1677ff; border-radius: 4rpx; font-size: 22rpx; }
.facilities { font-size: 24rpx; color: #52c41a; margin-top: 8rpx; }
.rating { font-size: 26rpx; color: #faad14; margin-top: 6rpx; }
.intro { font-size: 26rpx; color: #666; line-height: 1.7; margin-top: 12rpx; }

.section { background: #fff; padding: 24rpx; margin-bottom: 16rpx; }
.section-title { font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; }

.room-item { padding: 20rpx; border: 2rpx solid #eee; border-radius: 12rpx; margin-bottom: 12rpx; }
.room-active { border-color: #1677ff; background: #f0f5ff; }
.room-header { display: flex; justify-content: space-between; align-items: center; }
.room-name { font-size: 28rpx; font-weight: 600; }
.room-price { font-size: 28rpx; color: #e74c3c; font-weight: 600; }
.room-meta { font-size: 24rpx; color: #999; margin-top: 6rpx; }
.room-facilities { font-size: 22rpx; color: #666; margin-top: 4rpx; }

.form { }
.form-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.label { width: 140rpx; font-size: 28rpx; color: #333; }
.input { flex: 1; font-size: 28rpx; }
.picker { flex: 1; font-size: 28rpx; color: #333; }
.total { text-align: right; font-size: 32rpx; color: #e74c3c; font-weight: 600; margin-top: 16rpx; }

.review-item { padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.review-header { font-size: 26rpx; font-weight: 500; }
.review-content { font-size: 26rpx; color: #666; margin-top: 6rpx; }
.review-reply { font-size: 24rpx; color: #e74c3c; margin-top: 6rpx; padding-left: 16rpx; border-left: 2rpx solid #e74c3c; }

.bottom-bar { position: fixed; bottom: 0; width: 100%; padding: 16rpx 24rpx; background: #fff; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06); }
.book-btn { background: #1677ff; color: #fff; border-radius: 8rpx; font-size: 30rpx; }

.loading { text-align: center; padding: 60rpx; color: #999; }
.empty { text-align: center; padding: 60rpx; color: #999; font-size: 28rpx; }
