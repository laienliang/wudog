.container { min-height: 100vh; background: #f5f5f5; padding-bottom: 20rpx; }
.tag-scroll { white-space: nowrap; padding: 20rpx; background: #fff; }
.tag-item { display: inline-block; padding: 10rpx 24rpx; margin-right: 16rpx; background: #f0f0f0; border-radius: 30rpx; font-size: 26rpx; color: #666; }
.tag-active { background: #1677ff; color: #fff; }

.homestay-card { background: #fff; margin: 20rpx; border-radius: 12rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.card-img { width: 100%; height: 340rpx; }
.card-info { padding: 20rpx; }
.card-name { font-size: 32rpx; font-weight: 600; }
.card-addr { font-size: 24rpx; color: #999; margin-top: 6rpx; }
.card-tags { margin-top: 10rpx; }
.style-tag { display: inline-block; padding: 2rpx 12rpx; margin-right: 8rpx; background: #e6f7ff; color: #1677ff; border-radius: 4rpx; font-size: 22rpx; }
.card-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 12rpx; }
.rating { font-size: 24rpx; color: #faad14; }
.detail-link { font-size: 24rpx; color: #1677ff; }

.loading { text-align: center; padding: 60rpx; color: #999; }
.empty { text-align: center; padding: 60rpx; color: #999; font-size: 28rpx; }
.no-more { text-align: center; padding: 30rpx; color: #ccc; font-size: 24rpx; }
