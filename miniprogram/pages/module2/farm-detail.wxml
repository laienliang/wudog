<view class="container" wx:if="{{!loading && product}}">
  <image src="{{product.mainImage || '/images/placeholder.png'}}" mode="aspectFill" class="main-img" />

  <view class="info-card">
    <view class="name">{{product.name}}</view>
    <view class="price">¥{{product.price}}</view>
    <view class="meta" wx:if="{{product.origin}}">产地: {{product.origin}}</view>
    <view class="meta" wx:if="{{product.spec}}">规格: {{product.spec}}</view>
    <view class="meta" wx:if="{{product.avgRating}}">⭐{{product.avgRating}} ({{product.reviewCount}}评价)</view>
  </view>

  <view class="info-card" wx:if="{{product.shelfLife || product.storageMethod}}">
    <view class="meta" wx:if="{{product.shelfLife}}">保质期: {{product.shelfLife}}</view>
    <view class="meta" wx:if="{{product.storageMethod}}">储存方式: {{product.storageMethod}}</view>
  </view>

  <view class="info-card" wx:if="{{product.detail}}">
    <view class="section-title">商品详情</view>
    <rich-text nodes="{{product.detail}}" class="detail-content" />
  </view>

  <!-- Qty -->
  <view class="info-card">
    <view class="qty-row">
      <text>数量</text>
      <view class="qty-stepper">
        <view class="qty-btn" bindtap="onQtyMinus">-</view>
        <text class="qty-num">{{quantity}}</text>
        <view class="qty-btn" bindtap="onQtyPlus">+</view>
      </view>
    </view>
  </view>

  <!-- Reviews -->
  <view class="info-card">
    <view class="section-title">评价 ({{reviews.length}})</view>
    <view wx:if="{{reviews.length === 0}}" class="empty">暂无评价</view>
    <view class="review-item" wx:for="{{reviews}}" wx:key="id">
      <view class="review-header">用户{{item.userId}} ⭐{{item.rating}}</view>
      <view class="review-content" wx:if="{{item.content}}">{{item.content}}</view>
      <view class="review-reply" wx:if="{{item.merchantReply}}">商家回复: {{item.merchantReply}}</view>
    </view>
  </view>

  <view style="height:120rpx;"></view>
  <view class="bottom-bar">
    <button class="cart-btn" bindtap="addToCart">加入购物车</button>
    <button class="buy-btn" bindtap="buyNow">立即购买</button>
  </view>
</view>

<view wx:if="{{loading}}" class="loading">加载中...</view>
<view wx:if="{{!loading && !product}}" class="empty">商品不存在</view>
