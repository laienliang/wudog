.container { min-height: 100vh; background: #f5f5f5; }
.main-img { width: 100%; height: 500rpx; }
.info-card { background: #fff; padding: 24rpx; margin-bottom: 20rpx; }
.name { font-size: 36rpx; font-weight: 700; }
.price { font-size: 40rpx; color: #e74c3c; font-weight: 700; margin: 10rpx 0; }
.meta { font-size: 26rpx; color: #888; line-height: 1.8; }
.section-title { font-size: 30rpx; font-weight: 600; margin-bottom: 12rpx; }
.detail-content { font-size: 28rpx; line-height: 1.8; }
.qty-row { display: flex; align-items: center; justify-content: space-between; font-size: 28rpx; }
.qty-stepper { display: flex; align-items: center; gap: 16rpx; }
.qty-btn { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid #d9d9d9; border-radius: 8rpx; font-size: 32rpx; }
.qty-num { width: 60rpx; text-align: center; font-size: 28rpx; }
.review-item { padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.review-header { font-size: 26rpx; font-weight: 500; }
.review-content { font-size: 26rpx; color: #555; margin-top: 6rpx; }
.review-reply { font-size: 24rpx; color: #1677ff; background: #f6f8fa; padding: 8rpx 16rpx; margin-top: 6rpx; border-radius: 4rpx; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 16rpx 30rpx; box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05); display: flex; gap: 16rpx; }
.cart-btn { flex: 1; background: #1677ff; color: #fff; border: none; border-radius: 8rpx; font-size: 28rpx; padding: 20rpx 0; }
.buy-btn { flex: 1; background: #e74c3c; color: #fff; border: none; border-radius: 8rpx; font-size: 28rpx; padding: 20rpx 0; }
.empty { text-align: center; color: #999; padding: 60rpx; font-size: 28rpx; }
.loading { text-align: center; padding: 60rpx; color: #999; }
