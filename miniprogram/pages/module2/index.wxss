.container { min-height: 100vh; background: #f5f5f5; padding-bottom: 20rpx; }
.tab-bar { display: flex; background: #fff; padding: 0 30rpx; }
.tab-item { flex: 1; text-align: center; padding: 24rpx 0; font-size: 30rpx; color: #666; border-bottom: 4rpx solid transparent; }
.tab-item.active { color: #1677ff; border-bottom-color: #1677ff; font-weight: 600; }
.category-bar { white-space: nowrap; padding: 20rpx; background: #fff; margin-bottom: 10rpx; }
.cat-item { display: inline-block; padding: 10rpx 28rpx; margin-right: 16rpx; border-radius: 30rpx; font-size: 26rpx; color: #666; background: #f0f0f0; }
.cat-item.cat-active { color: #fff; background: #1677ff; }
.list { padding: 0 20rpx; }
.card { display: flex; background: #fff; border-radius: 12rpx; overflow: hidden; margin-bottom: 20rpx; }
.card-img { width: 240rpx; height: 160rpx; flex-shrink: 0; }
.card-info { flex: 1; padding: 20rpx; display: flex; flex-direction: column; justify-content: center; }
.card-title { font-size: 30rpx; font-weight: 600; margin-bottom: 6rpx; }
.card-desc { font-size: 24rpx; color: #888; margin-bottom: 4rpx; }
.card-meta { font-size: 22rpx; color: #aaa; }
.grid { display: flex; flex-wrap: wrap; padding: 10rpx 15rpx; }
.product-card { width: calc(50% - 20rpx); margin: 10rpx; background: #fff; border-radius: 12rpx; overflow: hidden; }
.product-img { width: 100%; height: 300rpx; }
.product-info { padding: 16rpx; }
.product-name { font-size: 28rpx; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.product-origin { font-size: 22rpx; color: #aaa; }
.product-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 8rpx; }
.product-price { font-size: 30rpx; color: #e74c3c; font-weight: 700; }
.product-sales { font-size: 22rpx; color: #aaa; }
.empty { text-align: center; color: #999; padding: 60rpx 0; font-size: 28rpx; }
.loading { text-align: center; padding: 30rpx; color: #999; font-size: 26rpx; }
.no-more { text-align: center; padding: 30rpx; color: #ccc; font-size: 24rpx; }
