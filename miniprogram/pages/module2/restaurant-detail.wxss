.container { min-height: 100vh; background: #f5f5f5; }
.main-img { width: 100%; height: 400rpx; }
.info-card { background: #fff; padding: 24rpx; margin-bottom: 20rpx; }
.name { font-size: 36rpx; font-weight: 700; margin-bottom: 10rpx; }
.meta-line { font-size: 26rpx; color: #888; line-height: 1.6; }
.intro { font-size: 28rpx; color: #555; margin-top: 12rpx; line-height: 1.7; }
.section { background: #fff; padding: 24rpx; margin-bottom: 20rpx; }
.section-title { font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; }
.dish-item { display: flex; padding: 12rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.dish-img { width: 140rpx; height: 140rpx; border-radius: 8rpx; flex-shrink: 0; }
.dish-info { flex: 1; padding-left: 20rpx; }
.dish-name { font-size: 28rpx; font-weight: 500; }
.signature-tag { font-size: 20rpx; color: #faad14; background: #fffbe6; padding: 2rpx 8rpx; border-radius: 4rpx; }
.dish-price { font-size: 30rpx; color: #e74c3c; font-weight: 600; margin-top: 6rpx; }
.dish-intro { font-size: 24rpx; color: #aaa; margin-top: 4rpx; }
.slot-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.slot-item { padding: 14rpx 32rpx; border: 1rpx solid #d9d9d9; border-radius: 8rpx; font-size: 26rpx; color: #666; }
.slot-item.slot-active { border-color: #1677ff; color: #1677ff; background: #e6f7ff; }
.form-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.label { width: 140rpx; font-size: 28rpx; color: #333; }
.input { flex: 1; font-size: 28rpx; }
.picker { flex: 1; font-size: 28rpx; color: #333; }
.review-item { padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.review-header { font-size: 26rpx; font-weight: 500; }
.review-content { font-size: 26rpx; color: #555; margin-top: 6rpx; }
.review-reply { font-size: 24rpx; color: #1677ff; background: #f6f8fa; padding: 8rpx 16rpx; margin-top: 6rpx; border-radius: 4rpx; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 16rpx 30rpx; box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05); }
.book-btn { width: 100%; background: #1677ff; color: #fff; border: none; border-radius: 8rpx; font-size: 30rpx; padding: 20rpx 0; }
.empty { text-align: center; color: #999; padding: 60rpx; font-size: 28rpx; }
.loading { text-align: center; padding: 60rpx; color: #999; }
