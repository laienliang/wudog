/**
 * 乌东文旅小程序全局样式
 * 基于视觉设计规范 V1.0
 */

/* 品牌色 */
page {
  --color-primary: #1F5FA8;
  --color-primary-dark: #0E3D75;
  --color-primary-light: #E8F1FB;
  --color-secondary-orange: #E85D2F;
  --color-secondary-green: #6B8E3D;
  --color-secondary-gold: #D4A14B;

  /* 中性色 */
  --color-text-primary: #1A1A1A;
  --color-text-secondary: #595959;
  --color-text-tertiary: #8C8C8C;
  --color-text-disabled: #BFBFBF;
  --color-border-primary: #E5E5E5;
  --color-border-secondary: #F0F0F0;
  --color-bg-primary: #FFFFFF;
  --color-bg-secondary: #F7F8FA;
  --color-bg-tertiary: #FAFAFA;

  /* 功能色 */
  --color-success: #52C41A;
  --color-warning: #FAAD14;
  --color-error: #FF4D4F;

  /* 间距 */
  --space-xs: 8rpx;
  --space-sm: 12rpx;
  --space-md: 16rpx;
  --space-lg: 24rpx;
  --space-xl: 32rpx;

  /* 圆角 */
  --radius-sm: 4rpx;
  --radius-md: 8rpx;
  --radius-lg: 12rpx;
  --radius-full: 999rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', PingFang SC,
    'Microsoft YaHei', source-fonts, sans-serif;
  font-size: 28rpx;
  color: var(--color-text-primary);
  background-color: var(--color-bg-secondary);
}

/* 苗族蜡染纹样装饰分割线 - 签名元素 */
.miao-divider {
  height: 12rpx;
  background-image: repeating-linear-gradient(
    90deg,
    var(--color-primary-light) 0,
    var(--color-primary-light) 8rpx,
    transparent 8rpx,
    transparent 16rpx,
    var(--color-primary) 16rpx,
    var(--color-primary) 20rpx,
    transparent 20rpx,
    transparent 28rpx
  );
  opacity: 0.6;
}

/* 通用卡片 */
.card {
  background: var(--color-bg-primary);
  border-radius: var(--radius-lg);
  padding: var(--space-md);
  margin: var(--space-md);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* 按钮 */
.btn-primary {
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: var(--radius-md);
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-primary:active {
  background: var(--color-primary-dark);
}

/* 价格 */
.price {
  color: var(--color-secondary-orange);
  font-weight: bold;
  font-size: 36rpx;
}

.price::before {
  content: '¥';
  font-size: 24rpx;
  margin-right: 2rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  font-size: 20rpx;
  background: var(--color-bg-secondary);
  color: var(--color-text-secondary);
}

.tag-primary {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.tag-orange {
  background: #FFF1EA;
  color: var(--color-secondary-orange);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-state .empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
}

.empty-state .empty-text {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  text-align: center;
}
