page {
  background: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
}

.container {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.btn-primary {
  background: #c9a96e;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
}

.btn-primary[disabled] {
  background: #ccc;
  color: #999;
}

.btn-default {
  background: #fff;
  color: #333;
  border: 1rpx solid #d9d9d9;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  padding: 20rpx 24rpx 0;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  padding: 16rpx 24rpx 24rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}

.loading-state {
  text-align: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}

.price {
  color: #f5222d;
  font-weight: 600;
}
