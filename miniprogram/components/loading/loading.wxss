.loading-wrap { display:flex; flex-direction:column; align-items:center; justify-content:center; padding:80rpx 0; }
.loading-spinner { width:48rpx; height:48rpx; border:4rpx solid #E5E7EB; border-top-color:var(--color-primary); border-radius:50%; animation:spin 0.8s linear infinite; }
.loading-text { margin-top:20rpx; font-size:26rpx; color:#9CA3AF; }
@keyframes spin { to { transform:rotate(360deg); } }
