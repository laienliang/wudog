<!-- 民宿卡片组件 — 瀑布流样式 -->
<view class="hs-card {{type}}" bindtap="onTap" data-id="{{item.id}}">
  <image class="hs-cover" src="{{item.cover_image}}" mode="aspectFill" lazy-load />
  <view class="hs-body">
    <view class="hs-name ellipsis">{{item.name}}</view>
    <view class="hs-address ellipsis">📍 {{item.address}}</view>
    <view class="hs-tags">
      <text class="tag tag-blue" wx:for="{{facilityList}}" wx:for-item="f" wx:key="*this" wx:if="{{index < 3}}">{{f}}</text>
    </view>
    <view class="hs-footer">
      <view class="hs-rating">
        <text class="stars">{{stars}}</text>
        <text class="rating-text">{{ratingText}}</text>
      </view>
      <view class="hs-price">
        <text class="price">¥<text class="price-large">{{item.min_price}}</text>起/晚</text>
      </view>
    </view>
  </view>
</view>
