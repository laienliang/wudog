.hero-image {
  width: 100%;
  height: 520rpx;
  border-radius: 28rpx;
}

.detail-head,
.section {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.category {
  color: #9a502a;
  font-weight: 700;
}

.price {
  font-size: 34rpx;
  font-weight: 700;
}

.stock.ok {
  color: #2d7d4c;
}

.stock.warn {
  color: #ad3724;
}

.detail-actions {
  display: flex;
  gap: 16rpx;
}

.section-title {
  font-weight: 700;
}

.sku-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 16rpx 0;
  border-top: 1px solid rgba(120, 74, 46, 0.12);
}
