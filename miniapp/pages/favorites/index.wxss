.login-panel,
.favorite-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.field {
  padding: 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.92);
}

.login-actions,
.favorite-actions {
  display: flex;
  gap: 16rpx;
}

.favorite-image {
  width: 100%;
  height: 300rpx;
  border-radius: 18rpx;
}

.favorite-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.category {
  color: #9a502a;
  font-weight: 700;
}

.favorite-title {
  font-size: 32rpx;
  font-weight: 700;
}

.price {
  font-weight: 700;
}
