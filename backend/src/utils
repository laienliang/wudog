/**
 * 将 TypeORM 实体转换为纯 JSON 对象
 * 移除原型链上的关系 getter，只保留数据属性
 * Issue #26: 同时剥离 uuid 字段，避免隐私泄露
 */
export function plainify(entity: any): any {
  if (entity == null) return null

  // 数组
  if (Array.isArray(entity)) {
    return entity.map(plainify)
  }

  // 普通对象
  const result: Record<string, any> = {}
  for (const key of Object.keys(entity)) {
    // Issue #26: 剥离 uuid 字段
    if (key === "uuid") continue

    // 跳过 TypeORM 内部属性（原型链上的）
    const descriptor = Object.getOwnPropertyDescriptor(entity, key)
    if (descriptor && descriptor.get) {
      // 这是一个 getter（通常是关系），跳过
      continue
    }
    const value = (entity as any)[key]
    if (value instanceof Date) {
      result[key] = value.toISOString()
    } else if (typeof value === 'object' && value !== null) {
      result[key] = plainify(value)
    } else {
      result[key] = value
    }
  }
  return result
}
