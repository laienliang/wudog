# 阿里云 OSS 配置
# 请将此文件复制为 .env 并填入真实配置

# 阿里云 AccessKey ID
OSS_ACCESS_KEY_ID=

# 阿里云 AccessKey Secret
OSS_ACCESS_KEY_SECRET=

# OSS Bucket 名称
OSS_BUCKET=wudong-travel

# OSS 区域（如 oss-cn-guiyang, oss-cn-hangzhou 等）
OSS_REGION=oss-cn-guiyang

# 上传目录前缀
OSS_DIR=uploads/

# 自定义域名（可选，不填则使用默认域名）
OSS_CNAME=

# 是否使用 HTTPS
OSS_SECURE=true

# Endpoint（可选，优先于 region，如 oss-cn-guiyang.aliyuncs.com）
OSS_ENDPOINT=

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_DATABASE=wudong_admin

# JWT 密钥
JWT_SECRET=wudong-admin-jwt-secret-2026

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
