{
  "name": "wudong-platform",
  "version": "1.0.0",
  "private": true,
  "description": "乌东文旅【衣食住行】综合服务平台 — Monorepo",
  "scripts": {
    "dev": "pnpm --recursive --parallel run dev",
    "dev:server": "pnpm --filter @wudong/server dev",
    "dev:web-pc": "pnpm --filter @wudong/web-pc dev",
    "dev:web-admin": "pnpm --filter @wudong/web-admin dev",
    "build": "pnpm --recursive run build",
    "build:server": "pnpm --filter @wudong/server build",
    "build:web-pc": "pnpm --filter @wudong/web-pc build",
    "build:web-admin": "pnpm --filter @wudong/web-admin build",
    "lint": "pnpm --recursive run lint",
    "lint:fix": "pnpm --recursive run lint:fix",
    "test": "pnpm --recursive run test",
    "test:server": "pnpm --filter @wudong/server test",
    "clean": "pnpm --recursive run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:migrate": "pnpm --filter @wudong/server db:migrate",
    "db:seed": "pnpm --filter @wudong/server db:seed"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.1.0",
  "devDependencies": {
    "@midwayjs/mock": "^3.16.5",
    "@types/node": "^20.11.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
