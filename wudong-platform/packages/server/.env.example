# ============================================================
# 乌东文旅平台 — 服务端环境变量配置示例
# 复制此文件为 .env 并填写实际值
# ============================================================

# ---- 应用 ----
NODE_ENV=development
SERVER_PORT=7001

# ---- 数据库 ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=wudong_platform

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT ----
JWT_SECRET=change-this-to-a-random-secret-key-in-production
JWT_ACCESS_EXPIRES=7d
JWT_REFRESH_EXPIRES=30d

# ---- OSS 文件存储 ----
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=wudong-platform
OSS_ENDPOINT=

# ---- 微信支付 ----
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=https://your-domain.com/api/v1/payment/notify

# ---- 微信小程序 ----
WECHAT_APP_SECRET=

# ---- 日志 ----
LOG_LEVEL=info
