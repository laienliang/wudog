{
  "name": "@wudong/server",
  "version": "1.0.0",
  "private": true,
  "description": "乌东文旅平台 — 后端服务（Midway.js）",
  "scripts": {
    "dev": "cross-env NODE_ENV=local midway-bin dev --ts --port=7001",
    "build": "midway-bin build",
    "start": "cross-env NODE_ENV=production node bootstrap.js",
    "start:dev": "cross-env NODE_ENV=development midway-bin dev --ts --port=7001",
    "test": "midway-bin test --ts",
    "test:cov": "midway-bin cov --ts",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "clean": "rm -rf dist output .nyc_output",
    "db:migrate:create": "typeorm migration:create",
    "db:migrate:run": "typeorm-ts-node-commonjs migration:run -d src/config/typeorm.config.ts",
    "db:migrate:revert": "typeorm-ts-node-commonjs migration:revert -d src/config/typeorm.config.ts",
    "db:seed": "ts-node src/common/utils/seed.ts"
  },
  "dependencies": {
    "@midwayjs/axios": "^3.16.8",
    "@midwayjs/cache": "^3.14.0",
    "@midwayjs/core": "^3.16.2",
    "@midwayjs/cross-domain": "^3.16.8",
    "@midwayjs/decorator": "^3.16",
    "@midwayjs/jwt": "^3.16.8",
    "@midwayjs/koa": "^3.16.8",
    "@midwayjs/logger": "^3.4.2",
    "@midwayjs/orm": "^3.4.3",
    "@midwayjs/redis": "^3.16.5",
    "@midwayjs/swagger": "^3.16.8",
    "@midwayjs/upload": "^3.16.8",
    "@midwayjs/validate": "^3.16.8",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "dayjs": "^1.11.10",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mysql2": "^3.9.0",
    "reflect-metadata": "^0.2.1",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@midwayjs/bootstrap": "^3.16.6",
    "@midwayjs/cli": "^2.1.1",
    "@midwayjs/mock": "^3.20.24",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/lodash": "^4.17.0",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0"
  }
}
