.page { min-height: 100vh; background: #f7f8fa; padding-bottom: 20rpx; }
.header { padding: 24rpx 20rpx; background: #fff; margin-bottom: 16rpx; }
.header-title { font-size: 20px; font-weight: 700; color: #1A1A1A; display: block; }
.header-count { font-size: 13px; color: #8C8C8C; margin-top: 4rpx; display: block; }

.loading { text-align: center; padding: 80rpx; color: #999; font-size: 13px; }
.empty { text-align: center; padding: 120rpx; color: #999; font-size: 14px; }

.feed-list { padding: 0 16rpx; }
.feed-card { background: #fff; border-radius: 14rpx; overflow: hidden; margin-bottom: 16rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06); }
.feed-img { width: 100%; height: 300rpx; background: #f5f5f5; display: block; }
.feed-body { padding: 14rpx 18rpx 18rpx; }
.feed-title { font-size: 14px; font-weight: 600; color: #1A1A1A; display: block; margin-bottom: 8rpx; }
.feed-stats { display: flex; gap: 16rpx; font-size: 11px; color: #BFBFBF; }
