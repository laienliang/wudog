.page { min-height: 100vh; background: #f7f8fa; padding: 20rpx; }
.header { margin-bottom: 20rpx; }
.header-title { font-size: 20px; font-weight: 700; color: #1A1A1A; }
.form { background: #fff; border-radius: 16rpx; padding: 24rpx 20rpx; }
.form-input { width: 100%; height: 44px; border: 1px solid #F0F0F0; border-radius: 8px; padding: 0 16rpx; font-size: 14px; margin-bottom: 16rpx; background: #FAFAFA; }
.form-textarea { width: 100%; height: 200px; border: 1px solid #F0F0F0; border-radius: 8px; padding: 12rpx 16rpx; font-size: 14px; margin-bottom: 16rpx; background: #FAFAFA; }
.form-group { display: flex; align-items: center; gap: 16rpx; margin-bottom: 24rpx; }
.form-label { font-size: 14px; color: #595959; }
.picker-value { font-size: 14px; color: #1F5FA8; }
.submit-btn { background: #1F5FA8; color: #fff; border: none; border-radius: 8px; font-size: 15px; font-weight: 600; padding: 16rpx 0; width: 100%; }
.submit-btn::after { border: none; }
