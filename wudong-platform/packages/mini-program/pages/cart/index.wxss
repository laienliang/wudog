.page { min-height: 100vh; background: #f7f8fa; padding-bottom: 60px; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding-top: 120px; }
.empty-icon { font-size: 64px; margin-bottom: 16px; }
.empty-text { font-size: 14px; color: #999; margin-bottom: 24px; }
.empty-btn { width: 160px; height: 40px; line-height: 40px; background: #1F5FA8; color: #fff; border-radius: 20px; font-size: 14px; }
.cart-item { display: flex; background: #fff; padding: 12px 16px; margin-bottom: 1px; align-items: center; gap: 12px; }
.item-image { width: 80px; height: 80px; border-radius: 8px; background: #f5f5f5; }
.item-info { flex: 1; }
.item-name { font-size: 14px; font-weight: 500; display: block; margin-bottom: 2px; }
.item-sku { font-size: 12px; color: #8C8C8C; display: block; margin-bottom: 4px; }
.item-price { font-size: 16px; font-weight: 700; color: #E85D2F; display: block; margin-bottom: 4px; }
.qty-control { display: flex; align-items: center; gap: 12px; }
.qty-btn { width: 24px; height: 24px; border-radius: 12px; background: #f5f5f5; text-align: center; line-height: 24px; font-size: 16px; }
.qty-num { font-size: 14px; min-width: 16px; text-align: center; }
.item-delete { color: #BFBFBF; font-size: 16px; padding: 8px; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; align-items: center; justify-content: space-between; padding: 8px 16px; background: #fff; border-top: 1px solid #f0f0f0; }
.total { font-size: 14px; }
.total-price { font-size: 20px; font-weight: 700; color: #E85D2F; }
.checkout-btn { height: 40px; line-height: 40px; background: #E85D2F; color: #fff; border-radius: 20px; padding: 0 32px; font-size: 14px; }
