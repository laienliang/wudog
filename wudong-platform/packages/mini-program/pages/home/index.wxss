.page { min-height: 100vh; background: #f7f8fa; }
.banner { background: linear-gradient(135deg, #1F5FA8, #0E3D75); padding: 40px 24px; text-align: center; color: #fff; }
.banner-title { font-size: 22px; font-weight: 700; display: block; margin-bottom: 8px; }
.banner-desc { font-size: 14px; opacity: 0.85; }
.grid { display: flex; flex-wrap: wrap; padding: 16px; gap: 8px; }
.grid-item { width: calc(25% - 6px); background: #fff; border-radius: 12px; padding: 16px 0; text-align: center; }
.grid-icon { font-size: 28px; display: block; margin-bottom: 4px; }
.grid-label { font-size: 12px; color: #595959; }
.section-title { font-size: 16px; font-weight: 600; padding: 16px 16px 8px; color: #1A1A1A; }
.product-grid { display: flex; flex-wrap: wrap; padding: 8px; gap: 8px; }
.product-card { width: calc(50% - 4px); background: #fff; border-radius: 8px; overflow: hidden; }
.product-image { width: 100%; height: 200px; background: #f5f5f5; }
.product-name { font-size: 14px; padding: 8px 10px 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.product-price { font-size: 16px; font-weight: 700; color: #E85D2F; padding: 0 10px 12px; }
