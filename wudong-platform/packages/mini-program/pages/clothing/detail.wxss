.page { min-height: 100vh; background: #f7f8fa; padding-bottom: 60px; }
.banner { width: 100%; height: 400px; }
.banner-img { width: 100%; height: 100%; }
.info-section { background: #fff; padding: 16px; margin-bottom: 8px; }
.product-name { font-size: 18px; font-weight: 600; margin-bottom: 4px; }
.product-subtitle { font-size: 13px; color: #8C8C8C; margin-bottom: 8px; }
.price-row { display: flex; align-items: baseline; gap: 8px; margin-bottom: 4px; }
.price { font-size: 24px; font-weight: 700; color: #E85D2F; }
.market-price { font-size: 13px; color: #BFBFBF; text-decoration: line-through; }
.sales { font-size: 12px; color: #999; margin-left: auto; }
.rating-row { font-size: 13px; color: #FAAD14; }
.section { background: #fff; padding: 16px; margin-bottom: 8px; }
.section-title { font-size: 15px; font-weight: 600; margin-bottom: 12px; color: #1A1A1A; }
.section-content { font-size: 14px; color: #595959; line-height: 1.6; }
.sku-list { display: flex; flex-wrap: wrap; gap: 8px; }
.sku-item { padding: 6px 16px; border-radius: 4px; border: 1px solid #e5e5e5; font-size: 14px; color: #595959; }
.sku-item.active { border-color: #1F5FA8; color: #1F5FA8; background: #E8F1FB; }
.qty-row { display: flex; justify-content: space-between; align-items: center; }
.qty-control { display: flex; align-items: center; gap: 16px; }
.qty-btn { width: 28px; height: 28px; border-radius: 14px; background: #f5f5f5; text-align: center; line-height: 28px; font-size: 18px; }
.qty-num { font-size: 16px; font-weight: 500; min-width: 20px; text-align: center; }
.review-item { padding: 12px 0; border-bottom: 1px solid #f0f0f0; }
.review-header { display: flex; justify-content: space-between; margin-bottom: 4px; font-size: 13px; color: #FAAD14; }
.review-time { color: #999; }
.review-content { font-size: 14px; color: #595959; }
.empty { text-align: center; padding: 24px; color: #999; font-size: 13px; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; height: 52px; background: #fff; border-top: 1px solid #f0f0f0; }
.bar-item { display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 10px; }
.bar-item:first-child { width: 60px; }
.cart-btn { flex: 1; background: #fff; color: #1F5FA8; font-size: 14px; }
.buy-btn { flex: 1; background: #E85D2F; color: #fff; font-size: 14px; }
.cart-btn text, .buy-btn text { font-size: 14px; font-weight: 500; }
