<view class="page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索商品..." bindinput="onSearchInput" bindconfirm="onSearch" confirm-type="search" value="{{keyword}}" />
    <text class="search-btn" bindtap="onSearch">搜索</text>
  </view>
  <!-- 搜索历史 -->
  <view wx:if="{{showHistory && searchHistory.length > 0}}" class="search-history">
    <view class="history-header"><text>搜索历史</text><text class="clear-history" bindtap="clearHistory">清除</text></view>
    <view class="history-tags"><text wx:for="{{searchHistory}}" wx:key="index" class="history-tag" bindtap="onHistoryTap" data-keyword="{{item}}">{{item}}</text></view>
  </view>

  <!-- 分类导航 -->
  <scroll-view class="category-bar" scroll-x>
    <view class="category-list">
      <view class="category-item {{!activeCategoryId ? 'active' : ''}}" bindtap="onCategoryTap" data-id="">全部分类</view>
      <view wx:for="{{categories}}" wx:key="id" class="category-item {{activeCategoryId === item.id ? 'active' : ''}}" bindtap="onCategoryTap" data-id="{{item.id}}">{{item.name}}</view>
    </view>
  </scroll-view>

  <!-- 排序 -->
  <view class="sort-bar">
    <view class="sort-item {{sortField === 'createdAt' ? 'active' : ''}}" bindtap="onSortTap" data-field="createdAt">最新</view>
    <view class="sort-item {{sortField === 'sales' ? 'active' : ''}}" bindtap="onSortTap" data-field="sales">销量</view>
    <view class="sort-item {{sortField === 'price' ? 'active' : ''}}" bindtap="onSortTap" data-field="price">价格</view>
    <view class="sort-item {{sortField === 'rating' ? 'active' : ''}}" bindtap="onSortTap" data-field="rating">评分</view>
  </view>

  <!-- 商品列表 -->
  <view class="product-grid">
    <view wx:for="{{products}}" wx:key="id" class="product-card" bindtap="onProductTap" data-id="{{item.id}}">
      <image class="product-image" src="{{item.mainImage || 'https://via.placeholder.com/300'}}" mode="aspectFill" />
      <view class="product-info">
        <view class="product-name">{{item.name}}</view>
        <view class="product-price">¥{{item.price}}</view>
        <view class="product-meta">
          <text>已售 {{item.sales || 0}}</text>
          <text>★ {{item.rating || 5.0}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
  <view class="load-more" wx:elif="{{!hasMore && products.length > 0}}">
    <text>没有更多了</text>
  </view>
</view>
