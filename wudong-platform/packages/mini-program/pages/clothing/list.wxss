.page { min-height: 100vh; background: #f7f8fa; }
.search-bar { display: flex; padding: 12px 16px; background: #fff; align-items: center; gap: 8px; }
.search-input { flex: 1; height: 36px; background: #f5f5f5; border-radius: 18px; padding: 0 16px; font-size: 14px; }
.search-btn { color: #1F5FA8; font-size: 14px; white-space: nowrap; }
.search-history { background: #fff; padding: 8px 16px 12px; border-bottom: 1px solid #f0f0f0; }
.history-header { display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 8px; }
.clear-history { color: #8C8C8C; }
.history-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.history-tag { padding: 3px 10px; background: #f5f5f5; border-radius: 12px; font-size: 12px; color: #595959; }
.category-bar { background: #fff; padding: 8px 16px; border-bottom: 1px solid #f0f0f0; }
.category-list { display: flex; gap: 8px; white-space: nowrap; }
.category-bar { background: #fff; padding: 8px 16px; border-bottom: 1px solid #f0f0f0; }
.category-list { display: flex; gap: 8px; white-space: nowrap; }
.category-item { padding: 4px 14px; font-size: 13px; color: #595959; border-radius: 14px; background: #f5f5f5; }
.category-item.active { background: #1F5FA8; color: #fff; }
.sort-bar { display: flex; background: #fff; padding: 8px 16px; gap: 24px; border-bottom: 1px solid #f0f0f0; }
.sort-item { font-size: 13px; color: #8C8C8C; }
.sort-item.active { color: #1F5FA8; font-weight: 600; }
.product-grid { display: flex; flex-wrap: wrap; padding: 8px; gap: 8px; }
.product-card { width: calc(50% - 4px); background: #fff; border-radius: 8px; overflow: hidden; }
.product-image { width: 100%; height: 200px; background: #f5f5f5; }
.product-info { padding: 8px 10px 12px; }
.product-name { font-size: 14px; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 4px; }
.product-price { font-size: 18px; font-weight: 700; color: #E85D2F; margin-bottom: 4px; }
.product-meta { display: flex; justify-content: space-between; font-size: 11px; color: #999; }
.load-more { text-align: center; padding: 16px; color: #999; font-size: 13px; }
