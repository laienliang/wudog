.page { padding: 24rpx; min-height: 100vh; background: #f5f7fa; }
.header { text-align: center; padding: 40rpx 0; }
.title { font-size: 40rpx; font-weight: 700; color: #1a1a1a; display: block; }
.subtitle { font-size: 26rpx; color: #999; margin-top: 12rpx; display: block; }
.form { background: #fff; border-radius: 16rpx; padding: 32rpx; }
.field { margin-bottom: 24rpx; }
.label { font-size: 28rpx; color: #333; display: block; margin-bottom: 12rpx; font-weight: 500; }
.input { width: 100%; height: 80rpx; border: 2rpx solid #e8e8e8; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; box-sizing: border-box; }
.picker { width: 100%; height: 80rpx; border: 2rpx solid #e8e8e8; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; line-height: 80rpx; color: #333; box-sizing: border-box; }
.btn { width: 100%; height: 88rpx; background: #1F5FA8; color: #fff; border-radius: 12rpx; font-size: 32rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; margin-top: 32rpx; }
.btn[disabled] { opacity: 0.6; }
.success-page { text-align: center; padding: 120rpx 40rpx; }
.success-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.success-title { font-size: 36rpx; font-weight: 700; color: #1a1a1a; display: block; }
.success-desc { font-size: 28rpx; color: #999; margin-top: 16rpx; display: block; }
