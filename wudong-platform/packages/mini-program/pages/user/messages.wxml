<view class="page">
  <view class="header"><text class="header-title">消息中心</text></view>
  <view class="msg-list">
    <view wx:for="{{messages}}" wx:key="id" class="msg-item">
      <view class="msg-icon">{{item.icon}}</view>
      <view class="msg-body">
        <text class="msg-title">{{item.title}}</text>
        <text class="msg-desc">{{item.desc}}</text>
      </view>
      <text class="msg-time">{{item.time}}</text>
    </view>
    <view wx:if="{{messages.length === 0}}" class="empty">暂无消息</view>
  </view>
</view>
