.page { min-height: 100vh; background: #f7f8fa; }
.profile { display: flex; align-items: center; gap: 16px; background: #fff; padding: 24px 16px; margin-bottom: 8px; }
.avatar { width: 64px; height: 64px; border-radius: 50%; background: #1F5FA8; color: #fff; text-align: center; line-height: 64px; font-size: 24px; flex-shrink: 0; }
.name { font-size: 18px; font-weight: 600; display: block; color: #1A1A1A; }
.phone { font-size: 13px; color: #999; }
.menu-list { background: #fff; }
.menu-item { display: flex; justify-content: space-between; padding: 16px 16px; font-size: 15px; border-bottom: 1px solid #f0f0f0; color: #333; cursor: pointer; }
