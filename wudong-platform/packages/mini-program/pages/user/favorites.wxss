.page { min-height: 100vh; background: #f7f8fa; padding: 8px; display: flex; flex-wrap: wrap; gap: 8px; }
.empty { width: 100%; text-align: center; padding: 80px 0; color: #999; font-size: 14px; }
.prod-card { width: calc(50% - 4px); background: #fff; border-radius: 8px; overflow: hidden; }
.prod-img { width: 100%; height: 180px; background: #f5f5f5; }
.prod-name { font-size: 14px; display: block; padding: 6px 10px 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.prod-price { font-size: 16px; font-weight: 700; color: #E85D2F; display: block; padding: 0 10px 10px; }
