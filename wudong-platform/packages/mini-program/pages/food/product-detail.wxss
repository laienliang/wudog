.page { min-height: 100vh; background: #f7f8fa; padding-bottom: 60px; }
.img { width: 100%; height: 300px; background: #f5f5f5; }
.info { background: #fff; padding: 16px; margin-bottom: 8px; }
.name { font-size: 18px; font-weight: 600; display: block; margin-bottom: 8px; }
.price { font-size: 24px; font-weight: 700; color: #E85D2F; display: block; margin-bottom: 4px; }
.unit { font-size: 14px; color: #999; font-weight: 400; }
.stock { font-size: 13px; color: #8C8C8C; display: block; margin-bottom: 12px; }
.desc { font-size: 14px; color: #595959; line-height: 1.6; display: block; }
.section { background: #fff; padding: 16px; margin-bottom: 8px; }
.section-title { font-size: 15px; font-weight: 600; display: block; margin-bottom: 12px; }
.review-item { padding: 10px 0; border-bottom: 1px solid #f0f0f0; }
.review-hd { display: flex; justify-content: space-between; margin-bottom: 4px; font-size: 13px; color: #FAAD14; }
.review-time { color: #999; }
.review-text { font-size: 14px; color: #595959; }
.empty { text-align: center; padding: 24px; color: #999; font-size: 13px; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 52px; display: flex; }
.cart-btn { flex: 1; background: #1F5FA8; color: #fff; text-align: center; line-height: 52px; font-size: 16px; }
