<view class="page">
  <view class="form-item">
    <text class="label">预订日期</text>
    <picker mode="date" value="{{date}}" bindchange="onDateChange">
      <text class="value">{{date || '请选择日期'}}</text>
    </picker>
  </view>
  <view class="form-item">
    <text class="label">用餐时段</text>
    <picker range="{{slots}}" range-key="name" bindchange="onSlotChange">
      <text class="value">{{selectedSlot ? selectedSlot.name + ' ¥' + selectedSlot.price : '请选择时段'}}</text>
    </picker>
  </view>
  <view class="form-item">
    <text class="label">人数</text>
    <picker mode="selector" range="{{guestOptions}}" bindchange="onGuestChange">
      <text class="value">{{guests}} 位</text>
    </picker>
  </view>
  <view class="form-item">
    <text class="label">联系人</text>
    <input class="input" placeholder="请输入姓名" bindinput="onNameInput" />
  </view>
  <view class="form-item">
    <text class="label">联系电话</text>
    <input class="input" placeholder="请输入手机号" bindinput="onPhoneInput" />
  </view>
  <button class="submit-btn" bindtap="onSubmit" loading="{{submitting}}">提交预订</button>
</view>
