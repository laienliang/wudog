.page { min-height: 100vh; background: #f7f8fa; padding-bottom: 20px; }
.section-title { font-size: 16px; font-weight: 600; padding: 16px 16px 8px; color: #1A1A1A; }
.restaurant-card { display: flex; background: #fff; margin: 8px 16px; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.restaurant-img { width: 120px; height: 100px; }
.restaurant-info { flex: 1; padding: 10px 12px; display: flex; flex-direction: column; gap: 4px; }
.restaurant-name { font-size: 15px; font-weight: 600; }
.restaurant-rating { font-size: 13px; color: #FAAD14; }
.restaurant-address { font-size: 12px; color: #999; }
.product-grid { display: flex; flex-wrap: wrap; padding: 8px; gap: 8px; }
.product-card { width: calc(50% - 4px); background: #fff; border-radius: 8px; overflow: hidden; }
.product-img { width: 100%; height: 180px; }
.product-name { font-size: 14px; display: block; padding: 6px 10px 2px; }
.product-price { font-size: 16px; font-weight: 700; color: #E85D2F; display: block; padding: 0 10px 10px; }
