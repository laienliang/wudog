<view class="page">
  <view class="section-title">🍽️ 推荐餐厅</view>
  <view wx:for="{{restaurants}}" wx:key="id" class="restaurant-card" bindtap="goToDetail" data-id="{{item.id}}">
    <image class="restaurant-img" src="{{item.coverImage}}" mode="aspectFill" />
    <view class="restaurant-info">
      <text class="restaurant-name">{{item.name}}</text>
      <text class="restaurant-rating">★ {{item.rating}}</text>
      <text class="restaurant-address">{{item.address}}</text>
    </view>
  </view>

  <view class="section-title">🛒 农产品特产</view>
  <view class="product-grid">
    <view wx:for="{{products}}" wx:key="id" class="product-card" bindtap="goToProduct" data-id="{{item.id}}">
      <image class="product-img" src="{{item.mainImage}}" mode="aspectFill" />
      <text class="product-name">{{item.name}}</text>
      <text class="product-price">¥{{item.price}}</text>
    </view>
  </view>
</view>
