.page { min-height: 100vh; background: #f7f8fa; padding-bottom: 20rpx; }
.search-bar { display: flex; padding: 16rpx; background: #fff; gap: 12rpx; align-items: center; }
.search-input { flex: 1; height: 36px; background: #f5f5f5; border-radius: 18px; padding: 0 16rpx; font-size: 14px; }
.search-btn { color: #1F5FA8; font-size: 14px; white-space: nowrap; }
.result-count { padding: 12rpx 16rpx; font-size: 12px; color: #8C8C8C; }
.loading { text-align: center; padding: 80rpx; color: #999; font-size: 13px; }
.empty { text-align: center; padding: 120rpx; color: #999; font-size: 14px; }
.feed-list { padding: 0 16rpx; }
.feed-card { background: #fff; border-radius: 14rpx; overflow: hidden; margin-bottom: 16rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06); }
.feed-img { width: 100%; height: 300rpx; background: #f5f5f5; display: block; }
.feed-body { padding: 14rpx 18rpx 18rpx; }
.feed-title { font-size: 14px; font-weight: 600; color: #1A1A1A; display: block; margin-bottom: 8rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.feed-meta { display: flex; justify-content: space-between; align-items: center; }
.feed-user { display: flex; align-items: center; gap: 8rpx; }
.feed-avatar { width: 28rpx; height: 28rpx; border-radius: 50%; background: #1F5FA8; color: #fff; text-align: center; line-height: 28rpx; font-size: 11px; }
.feed-name { font-size: 12px; color: #8C8C8C; }
.feed-stats { display: flex; gap: 12rpx; font-size: 11px; color: #BFBFBF; }
