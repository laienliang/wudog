<view class="page">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索游记、话题..." value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch" confirm-type="search" />
    <text class="search-btn" bindtap="onSearch">搜索</text>
  </view>
  <view wx:if="{{results.length > 0}}" class="result-count">共找到 {{total}} 条结果</view>
  <view wx:if="{{loading}}" class="loading"><text>搜索中...</text></view>
  <view wx:elif="{{searched && results.length === 0}}" class="empty"><text>未找到相关内容</text></view>
  <view class="feed-list">
    <view wx:for="{{results}}" wx:key="id" class="feed-card" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="feed-img" src="{{item.coverImage}}" mode="aspectFill" />
      <view class="feed-body">
        <text class="feed-title">{{item.title}}</text>
        <view class="feed-meta">
          <view class="feed-user">
            <view class="feed-avatar">{{item._avatar}}</view>
            <text class="feed-name">{{item.user_name || '用户'}}</text>
          </view>
          <view class="feed-stats"><text>❤️ {{item.likeCount || 0}}</text><text>💬 {{item.commentCount || 0}}</text></view>
        </view>
      </view>
    </view>
  </view>
</view>
