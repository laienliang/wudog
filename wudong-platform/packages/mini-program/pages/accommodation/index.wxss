.page { min-height: 100vh; background: #f7f8fa; padding-bottom: 20rpx; }
.section-title { padding: 24rpx 20rpx 4rpx; font-size: 20px; font-weight: 700; color: #1A1A1A; }
.section-desc { padding: 0 20rpx 16rpx; font-size: 13px; color: #8C8C8C; }
.empty-state { text-align: center; padding: 120rpx 0; color: #999; font-size: 14px; }
.homestay-list { padding: 0 16rpx; }
.homestay-card { background: #fff; border-radius: 12px; overflow: hidden; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.homestay-img { width: 100%; height: 360rpx; background: #f5f5f5; }
.homestay-info { padding: 16rpx 20rpx 20rpx; }
.homestay-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.homestay-name { font-size: 16px; font-weight: 600; color: #1A1A1A; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.homestay-rating { font-size: 13px; color: #FAAD14; font-weight: 600; margin-left: 8rpx; }
.facility-tags { display: flex; gap: 6rpx; margin-bottom: 12rpx; flex-wrap: wrap; }
.facility-tag { padding: 2rpx 14rpx; border-radius: 20rpx; background: #F5F5F5; color: #8C8C8C; font-size: 11px; }
.homestay-footer { display: flex; justify-content: space-between; align-items: center; }
.homestay-address { font-size: 12px; color: #BFBFBF; }
.homestay-price { font-size: 18px; font-weight: 700; color: #E85D2F; }
.price-unit { font-size: 12px; font-weight: 400; color: #BFBFBF; }
.load-more { text-align: center; padding: 24rpx 0; color: #999; font-size: 13px; }
