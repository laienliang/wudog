{
  "tsConfig": {
    "compilerOptions": {
      "baseUrl": ".",
      "module": "ESNext",
      "target": "ES2020",
      "lib": ["ES2020", "DOM", "DOM.Iterable"],
      "strict": true,
      "jsx": "preserve",
      "moduleResolution": "node",
      "resolveJsonModule": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "allowSyntheticDefaultImports": true,
      "paths": {
        "~/*": ["./*"],
        "@/*": ["./*"],
        "~~/*": ["./*"],
        "@@/*": ["./*"]
      }
    },
    "vueCompilerOptions": {
      "jsxDirectiveVersion": "4.0"
    }
  }
}
