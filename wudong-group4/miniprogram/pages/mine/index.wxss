.profile {
  text-align: center;
  padding: 60rpx 0;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-bottom: 16rpx;
}
.nickname {
  font-size: 32rpx;
  font-weight: bold;
}
.desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}
.login-btn {
  margin: 80rpx auto;
  width: 300rpx;
}

.menu-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  justify-content: space-between;
  padding: 30rpx;
  font-size: 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.menu-item:last-child {
  border-bottom: none;
}
