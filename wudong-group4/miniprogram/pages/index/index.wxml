<!--pages/index/index.wxml-->
<view class="container">
  <!-- Banner -->
  <view class="banner" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <text class="banner-title">探索乌东之美</text>
    <text class="banner-sub">景区门票 · 苗寨路线 · 一键预订</text>
  </view>

  <!-- 景区推荐 -->
  <view class="section-title">热门景区</view>
  <view class="card-grid">
    <block wx:for="{{spots}}" wx:key="id">
      <view class="card-col" bindtap="toScenicDetail" data-id="{{item.id}}">
        <view class="card">
          <view class="card-img-placeholder"></view>
          <view class="card-body">
            <view class="card-title">{{item.name}}</view>
            <view class="card-desc">{{item.address}}</view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 路线推荐 -->
  <view class="section-title">推荐路线</view>
  <view class="card-grid">
    <block wx:for="{{routes}}" wx:key="id">
      <view class="card-col" bindtap="toRouteDetail" data-id="{{item.id}}">
        <view class="card">
          <view class="card-img-placeholder"></view>
          <view class="card-body">
            <view class="card-title">{{item.name}}</view>
            <view class="card-desc">{{item.durationDays}}天行程</view>
            <view class="card-price">¥{{item.price}}</view>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
