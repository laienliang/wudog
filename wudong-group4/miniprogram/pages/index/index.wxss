.banner {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
}
.banner-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}
.banner-sub {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin: 20rpx 0 16rpx;
  padding-left: 10rpx;
}
