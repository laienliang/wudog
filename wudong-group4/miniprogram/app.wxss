/* app.wxss */
page {
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

.container {
  padding: 20rpx;
}

/* ---- Header ---- */
.app-header {
  background: #1677ff;
  color: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.app-header .logo {
  font-size: 34rpx;
  font-weight: bold;
}

/* ---- Card Grid ---- */
.card-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.card-grid .card-col {
  width: 48%;
  margin-bottom: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.card .card-img {
  width: 100%;
  height: 300rpx;
  background: #e8e8e8;
}
.card .card-img-placeholder {
  width: 100%;
  height: 300rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}
.card .card-body {
  padding: 20rpx;
}
.card .card-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card .card-desc {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card .card-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
  margin-top: 12rpx;
}

/* ---- Detail ---- */
.detail-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}
.detail-section .cover {
  width: 100%;
  height: 400rpx;
  background: #e8e8e8;
  border-radius: 12rpx;
}
.detail-section .title {
  font-size: 36rpx;
  font-weight: bold;
  margin-top: 20rpx;
  margin-bottom: 12rpx;
}
.detail-section .info {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}
.detail-section .desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
  line-height: 1.6;
}

/* ---- Ticket Item ---- */
.ticket-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  background: #fff;
}
.ticket-item .info {
  flex: 1;
}
.ticket-item .name {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}
.ticket-item .desc {
  font-size: 24rpx;
  color: #999;
}
.ticket-item .price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
  margin: 0 20rpx;
}

/* ---- Button ---- */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  color: #fff;
}
.btn-primary {
  background: #1677ff;
}
.btn-small {
  height: 56rpx;
  font-size: 26rpx;
  border-radius: 28rpx;
  padding: 0 32rpx;
}

/* ---- Order Card ---- */
.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.order-card .order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.order-card .order-name {
  font-size: 30rpx;
  font-weight: bold;
}
.order-card .order-status {
  font-size: 26rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.status-pending { color: #1677ff; background: #e6f0ff; }
.status-used { color: #52c41a; background: #f6ffed; }
.status-cancelled { color: #faad14; background: #fffbe6; }
.status-expired { color: #ff4d4f; background: #fff2f0; }

.order-card .order-meta {
  font-size: 24rpx;
  color: #999;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 12rpx;
}
.order-card .order-total {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: bold;
}
.order-card .order-uuid {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
  word-break: break-all;
}

/* ---- Bottom Bar ---- */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 100;
}
.bottom-bar .total {
  font-size: 28rpx;
}
.bottom-bar .total .price {
  color: #ff4d4f;
  font-weight: bold;
  font-size: 36rpx;
}
.bottom-bar .btn {
  width: 240rpx;
}

/* ---- Form ---- */
.form-group {
  margin-bottom: 24rpx;
}
.form-group .label {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 10rpx;
  display: block;
}
.form-group input,
.form-group picker,
.form-group textarea {
  width: 100%;
  padding: 16rpx 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
  background: #fff;
}

/* ---- Qty Selector ---- */
.qty-selector {
  display: inline-flex;
  align-items: center;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
}
.qty-selector .btn-dec,
.qty-selector .btn-inc {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  font-size: 32rpx;
}
.qty-selector .qty-val {
  width: 80rpx;
  text-align: center;
  font-size: 28rpx;
}

/* ---- Empty State ---- */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* ---- Back Nav ---- */
.back-nav {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #1677ff;
}

/* ---- Avatar Placeholder ---- */
.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin: 0 auto 16rpx;
}
